        }

        const MOOD_PROMPTS_EN = {
            bright: "bright citrusy lifted crystalline yuzu refreshing luminous",
            slow: "slow comforting warm cozy sweet gentle velvet round",
            floral: "floral delicate jasmine honeysuckle blossom perfume",
            adventurous: "adventurous bold daring spice unexpected layered",
            focus: "quiet focus contemplative tea clean transparent filter pen"
        };

        function getMoodBlock(moodId) {
            return {
                label: LuxuryI18n.t(`moods.${moodId}.title`),
                caption: LuxuryI18n.t(`moods.${moodId}.caption`),
                tastingDirection: LuxuryI18n.t(`moods.${moodId}.tastingDirection`),
                prompt: annapCoalesce(MOOD_PROMPTS_EN[moodId], "")
            };
        }

        function tFmt(path, vars) {
            let s = LuxuryI18n.t(path);
            Object.keys(vars || {}).forEach((k) => {
                s = s.split("{" + k + "}").join(vars[k]);
            });
            return s;
        }

        function flattenMenu(categories) {
            const out = [];
            for (const c of categories || []) {
                for (const it of c.items || []) {
                    out.push({ ...it, categoryName: c.name });
                }
            }
            return out;
        }

        function itemBlob(it) {
            return `${it.name || ""} ${it.description || ""} ${it.tastingNotes || ""} ${it.moodProfile || ""}`.toLowerCase();
        }

        function scoreForMood(moodId, it) {
            const t = itemBlob(it);
            const ac = annapCoalesce(it.acidityLevel, 0);
            const sw = annapCoalesce(it.sweetnessLevel, 0);
            const caf = annapCoalesce(it.caffeineLevel, 0);
            switch (moodId) {
                case "bright": {
                    let s = 0;
                    if (ac >= 4) s += 4;
                    if (/citrus|yuzu|lemon|orange|grapefruit|bright|lifted|crystalline|luminous|acid|apple|jasmine/.test(t)) s += 3;
                    if (/v60|pour|filter|clean|transparent/.test(t)) s += 2;
                    return s;
                }
                case "slow": {
                    let s = 0;
                    if (sw >= 4) s += 3;
                    if (/comfort|warm|butter|cocoa|velvet|gentle|round|slow|gelato|caramel|milk|oat|honey/.test(t)) s += 3;
                    if (/still|indulgent|afternoon|tender/.test(t)) s += 2;
                    return s;
                }
                case "floral": {
                    let s = 0;
                    if (/floral|blossom|honeysuckle|jasmine|rose|orange blossom|perfume|bloom|delicate|petal/.test(t)) s += 5;
                    if (ac >= 3 && ac <= 5) s += 1;
                    return s;
                }
                case "adventurous": {
                    let s = 0;
                    if (/pepper|fig|smoke|bold|spice|layer|adventur|three kicks|cocoa|cocoa nib|curveball/.test(t)) s += 4;
                    if (caf >= 4) s += 2;
                    if (/cardamom|saffron|salt|ristretto/.test(t)) s += 1;
                    return s;
                }
                case "focus": {
                    let s = 0;
                    if (/contemplative|tea|transparent|quiet|pen|filter|read|rain|crystalline|clean cup/.test(t)) s += 4;
                    if (sw <= 3 && ac >= 3) s += 2;
                    if (/v60|pour-over|pour over/.test(t)) s += 3;
                    return s;
                }
                default:
                    return 0;
            }
        }

        function pickItemsForMoodScored(moodId) {
            if (!moodMenuFlat || !moodMenuFlat.length) return [];
            const scored = moodMenuFlat.map((it) => ({ it, s: scoreForMood(moodId, it) }));
            scored.sort((a, b) => b.s - a.s);
            let list = scored.filter((x) => x.s > 0);
            if (list.length < 4) {
                const inList = new Set(list.map((x) => x.it.id));
                const rest = scored.filter((x) => !inList.has(x.it.id));
                list = list.concat(rest).slice(0, 6);
            } else list = list.slice(0, 6);
            return list;
        }

        function moodVisualPercent(rows, idx) {
            const scores = rows.map((r) => r.s);
            const mx = Math.max(...scores, 1);
            const mn = Math.min(...scores);
            const span = Math.max(1, mx - mn);
            const t = (rows[idx].s - mn) / span;
            let p = Math.round(54 + t * 40 - idx * 2);
            return Math.max(40, Math.min(96, p));
        }

        function moodPairingStrengthLabel(pct) {
            if (pct >= 90) return LuxuryI18n.t("ritual.pairingClose") || "Exceptionally close in this light";
            if (pct >= 80) return LuxuryI18n.t("ritual.pairingEcho") || "A natural echo of your mood";
            if (pct >= 68) return LuxuryI18n.t("ritual.pairingLine") || "Still on your line — worth reading";
            return LuxuryI18n.t("ritual.pairingNeighbor") || "A softer neighbor on the tray";
        }

        function moodPersonalityGlimpse(moodId) {
            return LuxuryI18n.t("moods." + moodId + ".glimpse") || "";
        }

        async function moodRunReadingRite(requestId) {
            if (document.documentElement.classList.contains("annap-guest-no-motion")) return;
            const el = document.getElementById("moodReadingRite");
            if (!el) return;
            const lines = [
                LuxuryI18n.t("ritual.readingRite1") || "Interpreting your palate in this light…",
                LuxuryI18n.t("ritual.readingRite2") || "Comparing texture against tonight’s parchment…",
                LuxuryI18n.t("ritual.readingRite3") || "Setting cups beside the mood you chose…"
            ];
            el.classList.remove("hidden");
            for (let i = 0; i < lines.length; i++) {
                if (requestId !== moodRequestId) {
                    el.classList.add("hidden");
                    el.innerHTML = "";
                    return;
                }
                el.innerHTML = `<p class="mood-reading-rite__line font-display text-[1.15rem] leading-snug text-[rgb(var(--fg))]">${escapeHtml(lines[i])}</p><div class="mood-reading-rite__bar" aria-hidden="true"><span></span></div>`;
                await sleep(820);
            }
            el.classList.add("hidden");
            el.innerHTML = "";
        }

        function tastingSnippet(it) {
            const raw = it.tastingNotes || it.description || "";
            if (!raw) return "";
            return raw.length > 160 ? raw.slice(0, 157).trimEnd() + "…" : raw;
        }

        async function renderMoodDrinkGrid(moodId, requestId) {
            const grid = document.getElementById("moodDrinkGrid");
            if (!grid) return;
            grid.classList.add("mood-grid--leave");
            await sleep(160);
            if (requestId !== moodRequestId) return;
            const items = pickItemsForMoodScored(moodId);
            grid.innerHTML = "";
            items.forEach((row, i) => {
                const it = row.it;
                const pct = moodVisualPercent(items, i);
                const card = document.createElement("article");
                card.className = "mood-drink-card surface-glass rounded-2xl p-5 ring-1 ring-[rgba(212,184,150,0.45)]";
                card.style.setProperty("--mi", String(i));
                card.style.setProperty("--mood-pct", String(pct));
                const snip = tastingSnippet(it);
                const tier = moodPairingStrengthLabel(pct);
                card.innerHTML = `
                    <p class="text-[10px] font-medium tracking-[0.26em] uppercase text-[rgb(var(--muted-2))]">${escapeHtml(it.categoryName || "")}</p>
                    <h3 class="mt-2 font-display text-lg tracking-tight text-[rgb(var(--fg))]">${escapeHtml(it.name || "")}</h3>
                    <p class="mt-2 font-display text-base tabular-nums text-[rgb(var(--accent))]">${escapeHtml(GuestInteractionContract.formatMoney(it.price))}</p>
                    <button type="button" class="btn-ink guest-hit mood-card-add mt-4 w-full justify-center py-3.5 text-sm font-normal tracking-wide" data-item-name="${escapeHtml(it.name || "")}">${escapeHtml(LuxuryI18n.t("menu.addToTray") || "Send to my table")}</button>
                    <div class="mood-card-meter mt-5" aria-hidden="true"><span style="width:${pct}%"></span></div>
                    <p class="mt-2 text-xs text-[rgb(var(--accent))] tabular-nums">${pct}% <span class="font-normal text-[rgb(var(--muted))]">· ${escapeHtml(tier)}</span></p>
                    <p class="mt-3 text-sm leading-relaxed text-[rgb(var(--muted))]">${escapeHtml(snip)}</p>
                    <div class="mt-5 flex items-center justify-end border-t border-[rgba(212,184,150,0.35)] pt-4">
                        <button type="button" data-ge-open-detail="${escapeHtml(String(it.id))}" class="guest-hit inline-flex min-h-11 items-center text-xs tracking-[0.18em] uppercase text-[rgb(var(--muted))] underline-offset-4 transition hover:text-[rgb(var(--fg))] hover:underline">${escapeHtml(LuxuryI18n.t("ritual.study"))}</button>
                    </div>`;
                (function () {
                    var qbtn = card.querySelector(".mood-card-add");
                    if (qbtn) qbtn.addEventListener("click", function (e) { quickAdd(it.id, undefined, e.currentTarget || e.target); });
                })();
                grid.appendChild(card);
            });
            grid.classList.remove("mood-grid--leave");
            void grid.offsetWidth;
            grid.classList.add("mood-grid--enter");
            window.setTimeout(() => grid.classList.remove("mood-grid--enter"), 520);
        }

        function syncRefinementChips() {
            document.querySelectorAll(".refine-chip").forEach((el) => {
                const on = el.getAttribute("data-refine") === moodActiveRefinement;
                el.setAttribute("aria-pressed", on ? "true" : "false");
                el.classList.toggle("is-selected", on);
            });
        }

        function mountRefinementChips() {
            const host = document.getElementById("moodRefinementChips");
            if (!host) return;
            host.innerHTML = "";
            const hint = document.createElement("p");
            hint.className = "text-[10px] font-medium tracking-[0.28em] uppercase text-[rgb(var(--muted-2))]";
            hint.textContent = LuxuryI18n.t("ritual.fineAdjustments");
            host.appendChild(hint);
            const row = document.createElement("div");
            row.className = "flex flex-wrap gap-2";
            for (const c of getRefineChips()) {
                const b = document.createElement("button");
                b.type = "button";
                b.className = "refine-chip";
                b.textContent = c.label;
                b.setAttribute("data-refine", c.id);
                b.setAttribute("aria-pressed", moodActiveRefinement === c.id ? "true" : "false");
                if (moodActiveRefinement === c.id) b.classList.add("is-selected");
                b.onclick = () => refineSommelier(c.id);
                row.appendChild(b);
            }
            host.appendChild(row);
        }

        function renderSommelierAlternatives(list) {
            const wrap = document.getElementById("moodAlternativesWrap");
            const root = document.getElementById("moodAlternatives");
            if (!wrap || !root) return;
            if (!list || !list.length) {
                wrap.classList.add("hidden");
                root.innerHTML = "";
                return;
            }
            wrap.classList.remove("hidden");
            root.innerHTML = "";
            for (let i = 0; i < list.length; i++) {
                const a = list[i];
                const mid = a.menuItemId != null ? a.menuItemId : a.MenuItemId;
                const row = document.createElement("div");
                row.style.setProperty("--alt-i", String(i));
                row.className =
                    "mood-alt-pair flex flex-col gap-3 rounded-2xl bg-[rgba(253,249,244,0.65)] px-4 py-4 ring-1 ring-[rgba(212,184,150,0.4)] lg:flex-row lg:items-center lg:justify-between";
                const text = document.createElement("div");
                text.className = "min-w-0";
                const nm = escapeHtml(a.name || "");
                const nt = escapeHtml(a.note || "");
                text.innerHTML = `<p class="font-display text-base tracking-tight text-[rgb(var(--fg))]">${nm}</p><p class="mt-1 text-xs leading-relaxed text-[rgb(var(--muted))]">${nt}</p>`;
                const tools = document.createElement("div");
