@section Scripts
{
@if (Model.SlimGuestBoot && !Model.HasSeatedTable)
{
    <script>
(function () {
    function mark(n) {
        if (window.AnnapGuestLanDebug && typeof AnnapGuestLanDebug.mark === "function") AnnapGuestLanDebug.mark(n);
        if (window.AnnapGuestLanDebug && typeof AnnapGuestLanDebug.log === "function") AnnapGuestLanDebug.log("slim:" + n);
    }
    function esc(s) {
        return String(s || "").replace(/&/g, "&amp;").replace(/</g, "&lt;");
    }
    document.addEventListener("DOMContentLoaded", function () {
        mark("slim-js-boot");
        var root = document.querySelector(".guest-main");
        var t0 = typeof performance !== "undefined" && performance.now ? performance.now() : Date.now();
        mark("menu-fetch-start");
        fetch(typeof window.__annapApiUrl === "function" ? window.__annapApiUrl("/api/menu") : "/api/menu", { headers: { Accept: "application/json" }, cache: "no-store" })
            .then(function (r) {
                if (!r.ok) throw new Error("HTTP " + r.status);
                return r.json();
            })
            .then(function (data) {
                var t1 = typeof performance !== "undefined" && performance.now ? performance.now() : Date.now();
                mark("menu-fetch-end");
                var ms = Math.round(t1 - t0);
                if (window.AnnapGuestLanDebug && AnnapGuestLanDebug.setMenu) AnnapGuestLanDebug.setMenu("OK slim " + ms + "ms");
                var cats = Array.isArray(data) ? data : (data.categories || []);
                var html = ["<div id=\"slim-menu-dump\" style=\"padding:12px;margin:12px 0;border:1px solid #555;border-radius:10px;background:rgba(0,0,0,0.35)\">"];
                html.push("<p><strong>Slim guest boot</strong> — mood / sommelier / tray / queue / i18n skipped. Set <code>Diagnostics:SlimGuestBoot</code> to <code>false</code> to restore full app.</p>");
                for (var i = 0; i < cats.length; i++) {
                    var c = cats[i];
                    html.push("<h3 style=\"margin:10px 0 6px;font-size:1rem\">" + esc(c.name) + "</h3><ul style=\"margin:0;padding-left:1.2rem\">");
                    var items = c.items || [];
                    for (var j = 0; j < items.length; j++) {
                        var it = items[j];
                        html.push("<li>" + esc(it.name) + " — " + esc(String(it.price)) + "</li>");
                    }
                    html.push("</ul>");
                }
                html.push("</div>");
                if (root) root.insertAdjacentHTML("afterbegin", html.join(""));
                mark("hydration-done");
            })
            .catch(function (err) {
                var msg = err && err.message ? err.message : String(err);
                if (window.AnnapGuestLanDebug && AnnapGuestLanDebug.setMenu) AnnapGuestLanDebug.setMenu("FAIL slim");
                mark("menu-error");
                if (root) {
                    var d = document.createElement("div");
                    d.style.cssText = "color:#f99;padding:12px;margin:12px 0";
                    d.textContent = "Slim menu fetch failed: " + msg;
                    root.insertBefore(d, root.firstChild);
                }
            });
    });
})();
    </script>
}
else
{
    <script>
        (function (w) {
            var c = typeof w.AnnapGuestBoot !== "undefined" ? w.AnnapGuestBoot : {};
            var on = w.__ANNAP_DEV_MODE === true && (w.__ANNAP_DEBUG === true || c.showBootChecklist === true);
            function nop() {}
            w.__annapGuestLog = on
                ? function () {
                      w.console.log.apply(w.console, arguments);
                  }
                : nop;
            w.__annapGuestWarn = on
                ? function () {
                      w.console.warn.apply(w.console, arguments);
                  }
                : nop;
            w.__annapGuestErr = on
                ? function () {
                      w.console.error.apply(w.console, arguments);
                  }
                : nop;
        })(window);
        const ANNAP_SERVER_VENUE_TABLE_ID = "@(Model.VenueTableId?.ToString("D") ?? "")";
        const GE_ENTRY_ROOT = document.getElementById("guest-experience-root");

        __annapGuestLog("[annap] boot step 1: guest script start");
        function annapBootOff(key) {
            var b = typeof window.AnnapGuestBoot !== "undefined" ? window.AnnapGuestBoot : {};
            return b[key] === true;
        }
        function annapCoalesce(a, b) {
            return a !== null && a !== undefined ? a : b;
        }
        function annapRenderPlainMenuFallback(reason) {
            try {
                __annapGuestLog("[annap] boot fallback: plain menu from /api/menu", reason);
                var mount = document.querySelector(".guest-main");
                if (!mount) return;
                var box = document.getElementById("annap-plain-menu-fallback");
                if (!box) {
                    box = document.createElement("div");
                    box.id = "annap-plain-menu-fallback";
                    box.setAttribute("style", "margin:12px;padding:12px;border:1px solid #666;border-radius:8px;background:#111;color:#eee;font:14px system-ui,sans-serif");
                    mount.insertBefore(box, mount.firstChild);
                }
                box.innerHTML = "<p>The menu is settling…</p>";
                fetch(typeof window.__annapApiUrl === "function" ? window.__annapApiUrl("/api/menu") : "/api/menu", { headers: { Accept: "application/json" }, cache: "no-store" })
                    .then(function (r) {
                        if (!r.ok) throw new Error("HTTP " + r.status);
                        return r.json();
                    })
                    .then(function (data) {
                        var cats = Array.isArray(data) ? data : (data.categories || []);
                        var html = ["<h2 style=\"font-size:16px\">Menu (compatibility fallback)</h2>"];
                        for (var fi = 0; fi < cats.length; fi++) {
                            var c = cats[fi];
                            html.push("<h3 style=\"margin:10px 0 4px\">" + String(c.name || "").replace(/</g, "&lt;") + "</h3><ul>");
                            var items = c.items || [];
                            for (var fj = 0; fj < items.length; fj++) {
                                var it = items[fj];
                                html.push("<li>" + String(it.name || "").replace(/</g, "&lt;") + "</li>");
                            }
                            html.push("</ul>");
                        }
                        box.innerHTML = html.join("");
                        __annapGuestLog("[annap] boot step 99: plain menu fallback rendered");
                    })
                    .catch(function (e) {
                        box.innerHTML = "<p>The menu did not arrive. Please try again in a moment.</p>";
                    });
            } catch (e2) {
                __annapGuestErr("[annap] fallback failed", e2);
            }
        }

        const HOME_CART_CATALOG = (function () {
            const node = document.getElementById("home-cart-catalog-json");
            if (!node) return [];
            try {
                return JSON.parse(node.textContent || "[]");
            } catch (_annap) {
                return [];
            }
        })();

        function catalogRow(id) {
            return HOME_CART_CATALOG.find((r) => String(r.id) === String(id));
        }

        GuestInteractionContract.bindPageContext({
            serverVt: ANNAP_SERVER_VENUE_TABLE_ID,
            migrateCatalog: {
                catalogRow,
                selectionFallback: () => LuxuryI18n.t("cart.selectionFallback") || "Selection"
            }
        });

        (function rehydrateHomeVtFromSession() {
            const srv = (ANNAP_SERVER_VENUE_TABLE_ID || "").trim();
            try {
                const u = new URL(window.location.href);
                const urlVt = (u.searchParams.get("vt") || "").trim();
                const stored = (sessionStorage.getItem("annap_venue_table_id") || "").trim();
                if (!GuestInteractionContract.isGuid(stored)) return;
                if (srv) return;
                if (urlVt) {
                    if (GuestInteractionContract.isGuid(urlVt)) sessionStorage.removeItem("annap_venue_table_id");
                    return;
                }
                u.searchParams.set("vt", stored);
                window.location.replace(u.pathname + u.search + u.hash);
            } catch (_annap) {
                /* ignore */
            }
        })();

        function readCartLines() {
            return GuestInteractionContract.getCartLines();
        }

        function writeCartLines(lines) {
            GuestInteractionContract.setCartLines(lines);
            updateCartPills();
        }

        function cartLineCount(lines) {
            return lines.reduce((a, l) => a + (Number(l.qty) || 0), 0);
        }

        function updateCartPills() {
            const lines = readCartLines();
            const count = cartLineCount(lines);
            const pill = document.getElementById("cartCountPill");
            if (!pill) return;
            if (count <= 0) {
                pill.classList.add("hidden");
                return;
            }
            pill.textContent = count;
            pill.classList.remove("hidden");
        }

        function quickAdd(menuItemId, guestLabel, sourceEl) {
            const gl =
                guestLabel !== undefined && guestLabel !== null
                    ? String(guestLabel).trim()
                    : typeof window.__annapActiveGroupGuestLabel === "string"
                      ? window.__annapActiveGroupGuestLabel.trim()
                      : "";
            const row = catalogRow(menuItemId);
            GuestInteractionContract.addItem({
                menuItemId,
                name: annapCoalesce(row && row.name, LuxuryI18n.t("cart.selectionFallback") || "Selection"),
                unitPrice: Number(annapCoalesce(row && row.price, 0)),
                selectionFallback: LuxuryI18n.t("cart.selectionFallback") || "Selection",
                sourceElement: sourceEl || null,
                guestLabel: gl
            });
            updateCartPills();
            renderCart();
        }

        function clearCart() {
            GuestInteractionContract.clearCart();
            updateCartPills();
            renderCart();
            document.getElementById("cartSubmitResult").textContent = "";
        }

        let guestCartLockY = 0;
        let homeOrderIdempotencyKey = null;
        let homeOrderSubmitInFlight = false;

        function openCart() {
            const overlay = document.getElementById("cartOverlay");
            const sheet = document.getElementById("cartSheet");
            const backdrop = document.getElementById("cartBackdrop");
            if (!overlay || !sheet || !backdrop) {
                try {
                    if (typeof console !== "undefined" && console.warn) {
                        console.warn("[annap-ge-boot] openCart skipped: cart overlay DOM missing");
                    }
                } catch (_oc) {}
                return;
            }
            renderCart();
            guestCartLockY = window.scrollY || document.documentElement.scrollTop || 0;
            document.documentElement.style.setProperty("--guest-lock-y", `-${guestCartLockY}px`);
            document.body.classList.add("guest-scroll-lock");
            document.body.style.top = `-${guestCartLockY}px`;

            overlay.classList.remove("hidden");
            requestAnimationFrame(() => {
                backdrop.classList.remove("opacity-0");
                backdrop.classList.add("opacity-100");
                sheet.classList.remove("translate-y-5", "opacity-0");
                sheet.classList.add("translate-y-0", "opacity-100");
            });
        }

        function closeCart() {
            const overlay = document.getElementById("cartOverlay");
            const sheet = document.getElementById("cartSheet");
            const backdrop = document.getElementById("cartBackdrop");
            if (!overlay || !sheet || !backdrop) return;

            backdrop.classList.add("opacity-0");
            backdrop.classList.remove("opacity-100");
            sheet.classList.add("translate-y-5", "opacity-0");
            sheet.classList.remove("translate-y-0", "opacity-100");

            window.setTimeout(() => {
                overlay.classList.add("hidden");
                document.body.classList.remove("guest-scroll-lock");
                document.body.style.top = "";
                document.documentElement.style.removeProperty("--guest-lock-y");
                window.scrollTo(0, guestCartLockY);
            }, 220);
        }

        function renderCart() {
            const linesAll = readCartLines();
            const el = document.getElementById("cartItemsHome");
            el.innerHTML = "";

            const guestCount =
                typeof window.__annapGroupGuestCount !== "undefined" && window.__annapGroupGuestCount != null
                    ? parseInt(window.__annapGroupGuestCount, 10)
                    : 0;
            const useGrouped =
                typeof GuestInteractionContract.buildGroupOrderTraySections === "function" &&
                typeof window.__annapGroupBrowseActive !== "undefined" &&
                window.__annapGroupBrowseActive &&
                guestCount >= 1;

            if (linesAll.length === 0) {
                const emptyMsg = LuxuryI18n.t("cart.empty") || "No items yet.";
                el.innerHTML = `<div class="surface-glass rounded-[1.35rem] px-5 py-4 text-sm text-[rgb(var(--muted))]">${escapeHtml(emptyMsg)}</div>`;
                return;
            }

            function appendLineRow(line) {
                const id = line.menuItemId;
                const qty = Number(line.qty) || 0;
                const displayName = line.name || id;
                const unit = Number(line.unitPrice) || 0;
                const row = document.createElement("div");
                row.className = "surface-glass flex items-center justify-between gap-3 rounded-[1.35rem] px-5 py-4";

                const left = document.createElement("div");
                left.className = "min-w-0";
                const gl = (line.guestLabel && String(line.guestLabel).trim()) || "";
                const guestHtml = gl
                    ? `<div class="mt-0.5 text-[11px] font-medium tracking-[0.12em] text-[rgb(var(--accent))]/90">${escapeHtml(gl)}</div>`
                    : "";
                left.innerHTML = `<div class="truncate text-sm text-[rgb(var(--fg))]">${escapeHtml(String(displayName))}</div>${guestHtml}<div class="mt-0.5 text-xs text-[rgb(var(--muted))] tabular-nums">${GuestInteractionContract.formatMoney(unit)} ${escapeHtml(LuxuryI18n.t("cart.unitEach") || "each")}</div>`;

                const right = document.createElement("div");
                right.className = "flex items-center gap-2";

                const minus = document.createElement("button");
                minus.className = "btn-quiet guest-hit inline-flex min-h-11 min-w-11 items-center justify-center px-0 text-sm";
                minus.textContent = "–";
                minus.onclick = () => {
                    GuestInteractionContract.adjustItemQuantity(id, -1, gl);
                    updateCartPills();
                    renderCart();
                };

                const qtyEl = document.createElement("span");
                qtyEl.className = "text-xs font-semibold text-[rgb(var(--fg))] w-10 text-center";
                qtyEl.textContent = `x${qty}`;

                const plus = document.createElement("button");
                plus.className = "btn-quiet guest-hit inline-flex min-h-11 min-w-11 items-center justify-center px-0 text-sm";
                plus.textContent = "+";
                plus.onclick = () => {
                    GuestInteractionContract.adjustItemQuantity(id, 1, gl);
                    updateCartPills();
                    renderCart();
                };

                right.appendChild(minus);
                right.appendChild(qtyEl);
                right.appendChild(plus);
                row.appendChild(left);
                row.appendChild(right);
                el.appendChild(row);
            }

            if (useGrouped) {
                const sections = GuestInteractionContract.buildGroupOrderTraySections(linesAll, guestCount);
                for (let si = 0; si < sections.length; si++) {
                    const sec = sections[si];
                    const head = document.createElement("div");
                    head.className =
                        "mb-1 mt-3 first:mt-0 text-[10px] font-medium tracking-[0.2em] text-[rgb(var(--accent))]";
                    head.textContent = sec.label;
                    el.appendChild(head);
                    if (!sec.lines || sec.lines.length === 0) {
                        const emptyRow = document.createElement("div");
                        emptyRow.className =
                            "surface-glass rounded-[1.35rem] px-4 py-3 text-xs text-[rgb(var(--muted))] mb-2";
                        emptyRow.textContent =
                            LuxuryI18n.t("cart.emptyGuestSection") || "No cups for this guest yet.";
                        el.appendChild(emptyRow);
                        continue;
                    }
                    for (const line of sec.lines) appendLineRow(line);
                }
                return;
            }

            const lines =
                typeof GuestInteractionContract.filterCartLinesForActiveGuest === "function"
                    ? GuestInteractionContract.filterCartLinesForActiveGuest(linesAll)
                    : linesAll;

            if (lines.length === 0) {
                const emptyMsg =
                    linesAll.length > 0 &&
                    typeof window.__annapGroupBrowseActive !== "undefined" &&
                    window.__annapGroupBrowseActive
                        ? LuxuryI18n.t("cart.emptyGuest") || "This guest has no cups on the tray yet."
                        : LuxuryI18n.t("cart.empty") || "No items yet.";
                el.innerHTML = `<div class="surface-glass rounded-[1.35rem] px-5 py-4 text-sm text-[rgb(var(--muted))]">${escapeHtml(emptyMsg)}</div>`;
                return;
            }

            for (const line of lines) appendLineRow(line);
        }

        async function submitCartOrder() {
            const lines = readCartLines();
            const result = document.getElementById("cartSubmitResult");
            const btn = document.getElementById("cartSubmitBtn");
            result.textContent = "";

            if (!GuestInteractionContract.getVenueTableId()) {
                result.textContent = LuxuryI18n.t("order.needTableScan") || LuxuryI18n.t("order.needTable") || "Please scan the table QR to begin.";
                return;
            }
            if (lines.length === 0) {
                result.textContent = LuxuryI18n.t("order.minOne") || "Add at least one item.";
                return;
            }
            if (homeOrderSubmitInFlight) return;
            homeOrderSubmitInFlight = true;
            try {
                if (!homeOrderIdempotencyKey && window.crypto && typeof window.crypto.randomUUID === "function")
                    homeOrderIdempotencyKey = window.crypto.randomUUID();
                else if (!homeOrderIdempotencyKey) homeOrderIdempotencyKey = String(Date.now());
                if (!homeOrderIdempotencyKey) {
                    result.textContent =
                        LuxuryI18n.t("order.submitFailed") || "We could not prepare your tray receipt. Refresh and try again.";
                    return;
                }

                if (btn) btn.setAttribute("disabled", "disabled");
                const prev = btn && btn.textContent;
                if (btn) btn.textContent = LuxuryI18n.t("order.submitting") || "Sending to the bar…";

                const items = lines.map((l) => {
                    const g = (l.guestLabel && String(l.guestLabel).trim()) || "";
                    return {
                        menuItemId: l.menuItemId,
                        quantity: l.qty,
                        notes: g ? `Guest: ${g}` : null
                    };
                });
                const vt = GuestInteractionContract.getVenueTableId();
                let res;
                try {
                    res = await fetch(typeof window.__annapApiUrl === "function" ? window.__annapApiUrl("/api/orders") : "/api/orders", {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json",
                            Accept: "application/json",
                            "Idempotency-Key": homeOrderIdempotencyKey
                        },
                        body: JSON.stringify({
                            venueTableId: vt,
                            items,
                            idempotencyKey: homeOrderIdempotencyKey,
                            paymentMethod: "CashOrCardAtCounter"
                        })
                    });
                } catch (_annap) {
                    if (window.GuestOrderQueue) window.GuestOrderQueue.enqueue(vt, items, homeOrderIdempotencyKey, "CashOrCardAtCounter");
                    result.textContent =
                        LuxuryI18n.t("order.queuedSoft") ||
                        "The line softened for a moment — we will place this tray when the room is steady again.";
                    if (btn) {
                        btn.textContent = prev;
                        btn.removeAttribute("disabled");
                    }
                    return;
                }

                const payload = await res.json().catch(function () {
                    return null;
                });
                if (!res.ok) {
                    const er = String((payload && payload.error) || "").toLowerCase();
                    let msg = LuxuryI18n.t("order.submitFailed") || "We could not send the tray just now.";
                    if (res.status === 400) {
                        homeOrderIdempotencyKey = null;
                        if (er.includes("scan") || er.includes("table qr") || er.includes("seat"))
                            msg = LuxuryI18n.t("order.needTableScan") || msg;
                        else if (er.includes("table") && (er.includes("not available") || er.includes("inactive")))
                            msg = LuxuryI18n.t("order.tableUnavailable") || msg;
                        else if (er.includes("menu") || er.includes("refresh"))
                            msg = LuxuryI18n.t("order.menuChanged") || msg;
                        else if (er.includes("at least one") || er.includes("tray"))
                            msg = LuxuryI18n.t("order.minOne") || msg;
                    } else if (res.status >= 500 || res.status === 429) {
                        if (window.GuestOrderQueue) window.GuestOrderQueue.enqueue(vt, items, homeOrderIdempotencyKey, "CashOrCardAtCounter");
                        msg =
                            LuxuryI18n.t("order.queuedSoft") ||
                            "The line softened for a moment — we will place this tray when the room is steady again.";
                    }
                    result.textContent = msg;
                    if (btn) {
                        btn.textContent = prev;
                        btn.removeAttribute("disabled");
                    }
                    return;
                }

                homeOrderIdempotencyKey = null;

                GuestInteractionContract.writeGuestOrderSession({
                    orderId: payload.id,
                    token: payload.guestSessionToken,
                    venueTableId: GuestInteractionContract.getVenueTableId(),
                    status: "submittedPendingPayment"
                });

                const oid = escapeHtml(String(payload.id));
                const submitted = escapeHtml(LuxuryI18n.t("order.submitted") || "The bar has received your tray.");
                const follow = escapeHtml(LuxuryI18n.t("order.followLink") || "Track your order");
                const trackHref = payload.trackUrl || `/track/${payload.id}?token=${encodeURIComponent(payload.guestSessionToken || "")}`;
                result.innerHTML = `${submitted} <span class="font-medium text-[rgb(var(--fg))] tabular-nums">${oid}</span>
                <a href="${String(trackHref).replace(/"/g, "&quot;")}" class="mt-3 block text-center text-[11px] font-medium tracking-[0.18em] uppercase text-[rgb(var(--muted))] underline-offset-4 transition hover:text-[rgb(var(--accent))] hover:underline">${follow}</a>`;
                GuestInteractionContract.clearCart();
                updateCartPills();
                renderCart();
                refreshActiveOrderBanner();
                if (typeof window.__annapRefreshTraySummary === "function") window.__annapRefreshTraySummary();
                if (btn) {
                    btn.textContent = prev;
                    btn.removeAttribute("disabled");
                }
            } finally {
                homeOrderSubmitInFlight = false;
            }
        }

        function readOrderSession() {
            return GuestInteractionContract.readGuestOrderSession();
        }

        async function refreshActiveOrderBanner() {
            const wrap = document.getElementById("activeOrderBanner");
            const link = document.getElementById("activeOrderTrackLink");
            if (!wrap || !link) return;
            const sess = readOrderSession();
            if (!sess || !GuestInteractionContract.getVenueTableId()) {
                wrap.classList.add("hidden");
                return;
            }
            try {
                const res = await fetch(
                    (typeof window.__annapApiUrl === "function"
                        ? window.__annapApiUrl(
                              "/api/track/orders/" +
                                  encodeURIComponent(sess.orderId) +
                                  "?token=" +
                                  encodeURIComponent(sess.token)
                          )
                        : `/api/track/orders/${encodeURIComponent(sess.orderId)}?token=${encodeURIComponent(sess.token)}`),
                    { headers: { Accept: "application/json" } }
                );
                if (res.status === 404) {
                    GuestInteractionContract.removeGuestOrderSession();
                    wrap.classList.add("hidden");
                    return;
                }
                if (!res.ok) throw new Error();
                const data = await res.json();
                if (data.isCancelled || data.isComplete) {
                    wrap.classList.add("hidden");
                    return;
                }
                link.href = `/track/${encodeURIComponent(sess.orderId)}?token=${encodeURIComponent(sess.token)}`;
                link.textContent = LuxuryI18n.t("order.followPreparation") || "Follow preparation";
                wrap.classList.remove("hidden");
            } catch (_annap) {
                wrap.classList.add("hidden");
            }
        }

        function sleep(ms) {
            return new Promise((r) => setTimeout(r, ms));
        }

        function escapeHtml(s) {
            return String(s)
                .replace(/&/g, "&amp;")
                .replace(/</g, "&lt;")
                .replace(/>/g, "&gt;")
                .replace(/"/g, "&quot;");
        }

        let moodMenuFlat = null;
        let moodRequestId = 0;
        let moodActiveId = null;
        let moodActiveRefinement = null;
        const SOMMELIER_SESSION_KEY = "annap_sommelier_session_v1";
        let sommelierLastLeadMenuItemId = null;

        function getSommelierSessionId() {
            try {
                const id = sessionStorage.getItem(SOMMELIER_SESSION_KEY);
                if (id && /^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-8][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$/.test(id))
                    return id;
            } catch (_annap) { /* ignore */ }
            return null;
        }

        function setSommelierSessionId(id) {
            try {
                if (id) sessionStorage.setItem(SOMMELIER_SESSION_KEY, id);
            } catch (_annap) { /* ignore */ }
        }

        function postSommelierQuietFeedback(opts) {
            const sid = getSommelierSessionId();
            const mid = opts && opts.menuItemId;
            if (!sid || !mid) return;
            const payload = {
                sessionId: sid,
                menuItemId: mid,
                outcome: (opts.outcome || "ignored").toLowerCase(),
                moodKey: opts.moodKey || moodActiveId,
                refinementKey: opts.refinementKey || moodActiveRefinement
            };
            const ac = new AbortController();
            const to = setTimeout(function () {
                ac.abort();
            }, 15000);
            fetch(typeof window.__annapApiUrl === "function" ? window.__annapApiUrl("/api/sommelier/feedback") : "/api/sommelier/feedback", {
                method: "POST",
                headers: { "Content-Type": "application/json", Accept: "application/json" },
                body: JSON.stringify(payload),
                signal: ac.signal
            })
                .catch(function (e) {
                    __annapGuestWarn("[annap] sommelier feedback failed", e);
                })
                .then(
                    function () {
                        clearTimeout(to);
                    },
                    function () {
                        clearTimeout(to);
                    }
                );
        }

        const REFINE_ORDER = ["softer", "brighter", "less_sweet", "more_adventurous", "low_caffeine"];

        function getRefineChips() {
            return REFINE_ORDER.map((id) => ({ id, label: LuxuryI18n.t(`refine.${id}.label`) }));
        }

        function refineSnippet(id) {
