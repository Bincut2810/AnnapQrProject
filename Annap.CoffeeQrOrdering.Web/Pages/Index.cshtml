                    const det = document.createElement("button");
                    det.type = "button";
                    det.setAttribute("data-ge-open-detail", String(mid));
                    det.className =
                        "guest-hit inline-flex min-h-11 items-center rounded-full px-4 text-[10px] font-medium tracking-[0.2em] uppercase text-[rgb(var(--muted))] ring-1 ring-[rgba(212,184,150,0.45)] transition hover:text-[rgb(var(--fg))]";
                    det.textContent = LuxuryI18n.t("ritual.study");
                    tools.appendChild(det);
                    const add = document.createElement("button");
                    add.type = "button";
                    add.className =
                        "btn-ink guest-hit min-h-11 shrink-0 rounded-full px-6 text-[10px] font-medium tracking-[0.2em] uppercase";
                    add.textContent = LuxuryI18n.t("menu.addToTray") || "Send to my table";
                    add.onclick = () => {
                        GuestInteractionContract.addItem({
                            menuItemId: mid,
                            name: (a && a.name) || (catRow && catRow.name) || LuxuryI18n.t("cart.selectionFallback") || "Selection",
                            unitPrice: Number.isFinite(Number(a && a.price)) ? Number(a.price) : Number(annapCoalesce(catRow && catRow.price, 0)),
                            selectionFallback: LuxuryI18n.t("cart.selectionFallback") || "Selection",
                            sourceElement: add
                        });
                        postSommelierQuietFeedback({
                            menuItemId: mid,
                            outcome: "accepted",
                            moodKey: moodActiveId,
                            refinementKey: moodActiveRefinement
                        });
                        updateCartPills();
                        renderCart();
                    };
                    tools.appendChild(add);
                }
                row.appendChild(text);
                row.appendChild(tools);
                root.appendChild(row);
            }
        }

        function applySommelierPayload(data, moodId) {
            const prevLead = sommelierLastLeadMenuItemId;
            const nextLead = data && data.recommendation && data.menuItemId ? data.menuItemId : null;

            if (prevLead && nextLead && prevLead !== nextLead) {
                postSommelierQuietFeedback({
                    menuItemId: prevLead,
                    outcome: "ignored",
                    moodKey: moodId,
                    refinementKey: moodActiveRefinement
                });
            }

            const sense = document.getElementById("moodSenseTag");
            const openEl = document.getElementById("moodOpeningLetter");
            const follow = document.getElementById("moodFollowUp");
            const secondWrap = document.getElementById("moodSecondGestureWrap");
            if (data && data.recommendation) {
                sommelierLastLeadMenuItemId = nextLead;
                openEl.textContent =
                    data.openingLetter ||
                    tFmt("ritual.sommelierDefaultOpening", { name: data.recommendation || "" });
                document.getElementById("moodRecName").textContent = annapCoalesce(data.recommendation, "");
                document.getElementById("moodTastingBody").textContent = annapCoalesce(data.tastingNotes, "");
                document.getElementById("moodToneBody").textContent = annapCoalesce(data.emotionalTone, "");
                document.getElementById("moodReasonBody").textContent = annapCoalesce(data.reason, "");
                if (data.followUpRefinement) {
                    follow.textContent = data.followUpRefinement;
                    if (secondWrap) secondWrap.classList.remove("hidden");
                } else {
                    follow.textContent = "";
                    if (secondWrap) secondWrap.classList.add("hidden");
                }
                if (data.senseTag && sense) {
                    sense.textContent = data.senseTag;
                    sense.classList.remove("hidden");
                } else if (sense) {
                    sense.classList.add("hidden");
                }
                const link = document.getElementById("moodRecLink");
                const add = document.getElementById("moodRecAdd");
                if (data.menuItemId && link) {
                    link.setAttribute("data-ge-open-detail", String(data.menuItemId));
                    link.classList.remove("hidden");
                } else if (link) link.classList.add("hidden");
                if (data.menuItemId && add) {
                    add.onclick = () => {
                        const row = catalogRow(data.menuItemId);
                        GuestInteractionContract.addItem({
                            menuItemId: data.menuItemId,
                            name: annapCoalesce(row && row.name, LuxuryI18n.t("cart.selectionFallback") || "Selection"),
                            unitPrice: Number(annapCoalesce(row && row.price, 0)),
                            selectionFallback: LuxuryI18n.t("cart.selectionFallback") || "Selection",
                            sourceElement: add
                        });
                        postSommelierQuietFeedback({
                            menuItemId: data.menuItemId,
                            outcome: "accepted",
                            moodKey: moodActiveId,
                            refinementKey: moodActiveRefinement
                        });
                        updateCartPills();
                        renderCart();
                    };
                    add.classList.remove("hidden");
                } else if (add) add.classList.add("hidden");
                renderSommelierAlternatives(data.alternatives);
            } else {
                if (prevLead) {
                    postSommelierQuietFeedback({
                        menuItemId: prevLead,
                        outcome: "ignored",
                        moodKey: moodId,
                        refinementKey: moodActiveRefinement
                    });
                }
                sommelierLastLeadMenuItemId = null;
                if (sense) sense.classList.add("hidden");
                openEl.textContent = LuxuryI18n.t("ritual.sommelierFallbackOpen");
                document.getElementById("moodRecName").textContent = getMoodBlock(moodId).label;
                document.getElementById("moodTastingBody").textContent =
                    LuxuryI18n.t("ritual.sommelierFallbackTasting");
                document.getElementById("moodToneBody").textContent = LuxuryI18n.t("ritual.sommelierFallbackTone");
                document.getElementById("moodReasonBody").textContent =
                    LuxuryI18n.t("ritual.sommelierFallbackReason");
                if (secondWrap) secondWrap.classList.add("hidden");
                follow && (follow.textContent = "");
                var _mrl = document.getElementById("moodRecLink");
                if (_mrl) _mrl.classList.add("hidden");
                var _mra = document.getElementById("moodRecAdd");
                if (_mra) _mra.classList.add("hidden");
                renderSommelierAlternatives([]);
            }
        }

        async function refineSommelier(chipId) {
            if (!moodActiveId) return;
            moodActiveRefinement = chipId;
            syncRefinementChips();
            const rid = ++moodRequestId;
            await loadSommelierLanguage(moodActiveId, rid, chipId);
        }

        async function loadSommelierLanguage(moodId, requestId, refinementId) {
            const shroud = document.getElementById("moodSommelierShroud");
            const card = document.getElementById("moodTastingCard");
            const inner = document.getElementById("moodSommelierInner");
            const cfg = getMoodBlock(moodId);
            const refinementText = refinementId ? refineSnippet(refinementId) : null;
            const viBoost = LuxuryI18n.getLang() === "vi" ? LuxuryI18n.t(`moods.${moodId}.prompt`) : "";
            const basePrompt = [cfg.prompt, viBoost].filter(Boolean).join(" | ");

            if (shroud) shroud.classList.remove("hidden");
            if (shroud) shroud.classList.add("flex");
            if (inner) inner.classList.add("mood-sommelier-inner--veil");
            if (card) card.classList.remove("is-revealed");

            await sleep(140);

            if (requestId !== moodRequestId) return;

            let data = null;
            try {
                const sid = getSommelierSessionId();
                const body = {
                    prompt: basePrompt,
                    moodKey: moodId,
                    moodLabel: cfg.label,
                    refinementKey: refinementId != null ? refinementId : null,
                    language: LuxuryI18n.getLang()
                };
                if (refinementText != null) body.refinement = refinementText;
                if (sid) body.sessionId = sid;
                const ac = new AbortController();
                const to = setTimeout(function () {
                    ac.abort();
                }, 28000);
                let res;
                try {
                    res = await fetch(typeof window.__annapApiUrl === "function" ? window.__annapApiUrl("/api/sommelier/suggest") : "/api/sommelier/suggest", {
                        method: "POST",
                        headers: { "Content-Type": "application/json", Accept: "application/json" },
                        body: JSON.stringify(body),
                        signal: ac.signal
                    });
                } finally {
                    clearTimeout(to);
                }
                const payload = await res.json().catch(function () {
                    return null;
                });
                data = res.ok ? payload : null;
                if (data && data.sessionId) setSommelierSessionId(data.sessionId);
            } catch (e) {
                __annapGuestWarn("[annap] sommelier suggest failed", e);
                data = null;
            }

            if (requestId !== moodRequestId) return;

            applySommelierPayload(data, moodId);

            if (shroud) shroud.classList.add("hidden");
            if (shroud) shroud.classList.remove("flex");
            if (inner) inner.classList.remove("mood-sommelier-inner--veil");

            if (card) void card.offsetWidth;
            if (card) card.classList.add("is-revealed");
            syncRefinementChips();
        }

        async function selectMood(moodId) {
            if (!MOOD_PROMPTS_EN[moodId]) return;
            const prevMood = moodActiveId;
            const prevRef = moodActiveRefinement;
            if (prevMood && prevMood !== moodId && sommelierLastLeadMenuItemId) {
                postSommelierQuietFeedback({
                    menuItemId: sommelierLastLeadMenuItemId,
                    outcome: "ignored",
                    moodKey: prevMood,
                    refinementKey: prevRef
                });
            }
            if (prevMood && prevMood !== moodId) sommelierLastLeadMenuItemId = null;

            const requestId = ++moodRequestId;
            moodActiveId = moodId;
            moodActiveRefinement = null;

            document.querySelectorAll(".mood-pill").forEach((btn) => {
                const on = btn.getAttribute("data-mood") === moodId;
                btn.setAttribute("aria-selected", on ? "true" : "false");
                btn.classList.toggle("is-selected", on);
            });

            const results = document.getElementById("moodResults");
            const cap = document.getElementById("moodFilterCaption");
            const tastingDir = document.getElementById("moodTastingDirection");
            if (results) results.dataset.ritualMood = moodId;
            if (tastingDir) {
                const b = getMoodBlock(moodId);
                tastingDir.textContent = b.tastingDirection;
            }
            if (cap) cap.textContent = getMoodBlock(moodId).caption;
            if (results) {
                results.classList.remove("hidden");
                results.classList.remove("mood-results");
                void results.offsetWidth;
                results.classList.add("mood-results");
            }

            mountRefinementChips();

            const glimpse = document.getElementById("moodPersonalityGlimpse");
            if (glimpse) {
                const line = moodPersonalityGlimpse(moodId);
                if (line) {
                    glimpse.textContent = line;
                    glimpse.classList.remove("hidden");
                } else glimpse.classList.add("hidden");
            }

            await moodRunReadingRite(requestId);

            if (annapBootOff("disableSommelierBoot")) {
                if (window.AnnapGuestBootHarness) AnnapGuestBootHarness.markSkipped("sommelier");
                await renderMoodDrinkGrid(moodId, requestId);
            } else {
                await Promise.all([renderMoodDrinkGrid(moodId, requestId), loadSommelierLanguage(moodId, requestId, null)]);
            }
        }

        async function initMoodCatalogCore() {
            const err = document.getElementById("moodCatalogErr");
            const dbg = window.AnnapGuestLanDebug;
            const t0 = typeof performance !== "undefined" && performance.now ? performance.now() : Date.now();
            if (dbg && dbg.setMenu) dbg.setMenu("…");
            try {
                if (err) {
                    err.classList.add("hidden");
                    err.textContent = "";
                }
                const ac = new AbortController();
                const to = setTimeout(function () {
                    ac.abort();
                }, 22000);
                let res;
                try {
                    res = await fetch(typeof window.__annapApiUrl === "function" ? window.__annapApiUrl("/api/menu") : "/api/menu", {
                        headers: { Accept: "application/json" },
                        cache: "no-store",
                        signal: ac.signal
                    });
                } finally {
                    clearTimeout(to);
                }
                if (!res.ok) throw new Error("menu http " + res.status);
                const raw = await res.json();
                const categories = Array.isArray(raw) ? raw : raw.categories || [];
                moodMenuFlat = flattenMenu(categories);
                const ms = Math.round((typeof performance !== "undefined" && performance.now ? performance.now() : Date.now()) - t0);
                __annapGuestLog("[annap] boot step 5: menu json ok " + ms + "ms items=" + (moodMenuFlat ? moodMenuFlat.length : 0));
                if (dbg && dbg.setMenu) dbg.setMenu("OK · " + ms + "ms");
                if (window.AnnapGuestBootHarness) AnnapGuestBootHarness.row("mood", "ok");
            } catch (e) {
                const ms = Math.round((typeof performance !== "undefined" && performance.now ? performance.now() : Date.now()) - t0);
                __annapGuestErr("[annap] menu bootstrap failed", e);
                if (dbg && dbg.setMenu) dbg.setMenu("FAIL · " + ms + "ms");
                if (err) {
                    err.textContent = !navigator.onLine
                        ? LuxuryI18n.t("ritual.catalogOffline") ||
                          "The room is quiet — we are holding yesterday's list until the line steadies."
                        : LuxuryI18n.t("ritual.catalogErr");
                    err.classList.remove("hidden");
                }
                moodMenuFlat = [];
                annapRenderPlainMenuFallback(e);
            }
        }

        async function initMoodCatalog() {
            if (annapBootOff("disableMoodCatalog")) {
                __annapGuestLog("[annap] mood catalog disabled (diag/safe)");
                if (window.AnnapGuestBootHarness) {
                    AnnapGuestBootHarness.markSkipped("menu");
                    AnnapGuestBootHarness.markSkipped("mood");
                }
                return;
            }
            var H = window.AnnapGuestBootHarness;
            try {
                if (H && typeof H.runTimed === "function")
                    await H.runTimed("menu", 5000, function () {
                        return initMoodCatalogCore();
                    });
                else await initMoodCatalogCore();
            } catch (te) {
                __annapGuestWarn("[annap] menu subsystem aborted", te);
                moodMenuFlat = [];
            }
        }

        function bootGuestExperience() {
            __annapGuestLog("[annap] boot step 3: bootGuestExperience start");
            var dbg = window.AnnapGuestLanDebug;
            var H = window.AnnapGuestBootHarness;
            try {
                try {
                    if (ANNAP_SERVER_VENUE_TABLE_ID) sessionStorage.setItem("annap_venue_table_id", ANNAP_SERVER_VENUE_TABLE_ID);
                } catch (_annap) {
                    /* ignore */
                }
            if (dbg && dbg.setHub) dbg.setHub("N/A");

            __annapGuestLog("[annap] starting tray/vt");
            try {
                if (typeof console !== "undefined" && console.log) {
                    console.log("[annap-ge-boot] bootGuestExperience", {
                        hasGeRoot: !!GE_ENTRY_ROOT,
                        seatedVt: (ANNAP_SERVER_VENUE_TABLE_ID || "").trim() || null,
                        menuFirstArrival: @(Model.MenuFirstArrival ? "true" : "false")
                    });
                }
                if (!GE_ENTRY_ROOT) {
                    GuestInteractionContract.setTrayOpener(openCart);
                } else {
                    if (typeof console !== "undefined" && console.log) {
                        console.log("[annap-ge-boot] skip setTrayOpener(openCart) on seated arrival; order-tray-dock wires tray");
                    }
                }
                GuestInteractionContract.navigation.applyVtNavPatches();
                __annapGuestLog("[annap] tray/vt ok");
            } catch (eTv) {
                __annapGuestErr("[annap] tray/vt failed", eTv);
            }

            __annapGuestLog("[annap] starting i18n DOM");
            try {
                LuxuryI18n.applyDom();
                __annapGuestLog("[annap] i18n DOM ok");
            } catch (eI18n) {
                __annapGuestErr("[annap] i18n DOM failed", eI18n);
            }
            __annapGuestLog("[annap] boot step 4: i18n DOM applied");

            try {
                document.addEventListener("luxury:i18n-changed", function () {
                    LuxuryI18n.applyDom();
                    if (!GE_ENTRY_ROOT) {
                        mountRefinementChips();
                        syncRefinementChips();
                    }
                    if (!annapBootOff("disableCartHydration")) {
                        renderCart();
                        refreshActiveOrderBanner();
                    }
                    const cap = document.getElementById("moodFilterCaption");
                    const tastingDir = document.getElementById("moodTastingDirection");
                    if (moodActiveId && cap && tastingDir) {
                        const b = getMoodBlock(moodActiveId);
                        cap.textContent = b.caption;
                        tastingDir.textContent = b.tastingDirection;
                    }
                });
            } catch (eL) {
                __annapGuestErr("[annap] i18n listener failed", eL);
            }

            try {
                window.addEventListener("online", function () {
                    document.dispatchEvent(new CustomEvent("annap:network-online"));
                    if (!GE_ENTRY_ROOT && !annapBootOff("disableMoodCatalog")) void initMoodCatalog();
                    if (!annapBootOff("disableGuestQueue") && window.GuestOrderQueue && typeof window.GuestOrderQueue.flush === "function")
                        void window.GuestOrderQueue.flush();
                });
            } catch (eOn) {
                __annapGuestErr("[annap] online listener failed", eOn);
            }

            __annapGuestLog("[annap] starting mood catalog");
            if (!GE_ENTRY_ROOT) {
                void initMoodCatalog();
            } else {
                __annapGuestLog("[annap] seated guest entry — mood catalog not required for arrival flow");
                if (window.AnnapGuestBootHarness) {
                    AnnapGuestBootHarness.markSkipped("menu");
                    AnnapGuestBootHarness.markSkipped("mood");
                    AnnapGuestBootHarness.markSkipped("sommelier");
                }
            }

            __annapGuestLog("[annap] starting mood UI chips");
            try {
                if (!annapBootOff("disableMoodCatalog") && !GE_ENTRY_ROOT) {
                    mountRefinementChips();
                    __annapGuestLog("[annap] mood UI ok");
                } else if (H && !GE_ENTRY_ROOT) {
                    H.markSkipped("mood");
                }
            } catch (eM) {
                __annapGuestErr("[annap] mood UI failed", eM);
            }
            __annapGuestLog("[annap] boot step 6a: mood UI init");
            __annapGuestLog("[annap] boot step 6: mood catalog init dispatched");

            __annapGuestLog("[annap] starting cart hydration");
            try {
                updateCartPills();
                if (!annapBootOff("disableCartHydration")) {
                    renderCart();
                    refreshActiveOrderBanner();
                    if (H) H.row("hydration", "ok");
                    __annapGuestLog("[annap] cart hydration ok");
                } else {
                    if (H) H.markSkipped("hydration");
                    __annapGuestLog("[annap] cart hydration skipped (diag/safe)");
                }
            } catch (eC) {
                __annapGuestErr("[annap] cart hydration failed", eC);
                if (H) H.row("hydration", "fail");
            }
            __annapGuestLog("[annap] boot step 7: cart init + hydration pass done");

            if (H) {
                H.row("signalr", "skip");
                if (annapBootOff("disableGuestQueue")) H.markSkipped("queue");
                H.markSkipped("observers");
                if (annapBootOff("disableSommelierBoot")) H.markSkipped("sommelier");
            }
            if (H && typeof H.markHydrationDone === "function") H.markHydrationDone();
            } catch (eBoot) {
                __annapGuestErr("[annap] guest boot failed", eBoot);
                if (dbg && dbg.log) dbg.log("boot err");
                annapRenderPlainMenuFallback(eBoot);
                if (H && typeof H.markHydrationDone === "function") H.markHydrationDone();
            }
        }

        function annapStartHomeGuestBoot() {
            if (annapBootOff("disableI18n")) {
                __annapGuestLog("[annap] starting i18n (skipped diag/safe)");
                if (window.AnnapGuestBootHarness) AnnapGuestBootHarness.markSkipped("i18n");
                try {
                    bootGuestExperience();
                } catch (bootErr0) {
                    __annapGuestErr("[annap] bootGuestExperience threw", bootErr0);
                    annapRenderPlainMenuFallback(bootErr0);
                }
                return;
            }
            var H = window.AnnapGuestBootHarness;
            __annapGuestLog("[annap] starting i18n");
            var i18nPromise = window.LuxuryI18n && window.LuxuryI18n.ready ? window.LuxuryI18n.ready : Promise.resolve();
            var gate =
                H && typeof H.runTimed === "function"
                    ? H.runTimed("i18n", 5000, function () {
                          return i18nPromise;
                      })
                    : i18nPromise;
            gate.then(
                function () {
                    __annapGuestLog("[annap] i18n ok");
                    __annapGuestLog("[annap] boot step 2: i18n bundles ready");
                    try {
                        bootGuestExperience();
                    } catch (bootErr) {
                        __annapGuestErr("[annap] bootGuestExperience threw", bootErr);
                        annapRenderPlainMenuFallback(bootErr);
                    }
                },
                function (e) {
                    __annapGuestErr("[annap] i18n failed or timeout", e);
                    try {
                        bootGuestExperience();
                    } catch (bootErr2) {
                        annapRenderPlainMenuFallback(bootErr2);
                    }
                }
            );
        }

        document.addEventListener("annap:guest-interaction", function (ev) {
            var d = ev && ev.detail;
            if (!d || (d.type !== "cartUpdated" && d.type !== "activeGuestChanged")) return;
            try {
                if (typeof updateCartPills === "function") updateCartPills();
                if (typeof renderCart === "function") renderCart();
            } catch (_cartUi) {
                /* ignore */
            }
        });

        try {
            annapStartHomeGuestBoot();
        } catch (topBootErr) {
            __annapGuestErr("[annap] boot outer failure", topBootErr);
            annapRenderPlainMenuFallback(topBootErr);
        }
    </script>
@if (Model.HasSeatedTable)
{
    <script src="~/js/arrival/choreography.js" asp-append-version="true"></script>
    <script src="~/js/guest-discovery-duck.js" asp-append-version="true"></script>
    <script src="~/js/guest-experience.js" asp-append-version="true"></script>
    <script src="~/js/annap-runtime-report.js" asp-append-version="true"></script>
    <script src="~/js/drink-detail-renderer.js" asp-append-version="true"></script>
    <script src="~/js/drink-detail-modal.js" asp-append-version="true"></script>
    <script src="~/js/guest-bank-transfer.js" asp-append-version="true"></script>
    <script src="~/js/order-tray-dock.js" asp-append-version="true"></script>
    <script>
        if (typeof window.annapStartOrderTrayDock === "function") window.annapStartOrderTrayDock();
    </script>
    <script src="~/js/menu-browse-cards.js" asp-append-version="true"></script>
}
}
