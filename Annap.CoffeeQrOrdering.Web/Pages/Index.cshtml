@page
@model IndexModel
@using System.Text.Json
@using Annap.CoffeeQrOrdering.Web.Services
@{
    ViewData["Title"] = Model.HasSeatedTable ? "Arrive" : Model.QrScanInvalid || Model.TableHandoffInvalid ? "Table" : "Order";
    if (Model.QrScanInvalid || Model.TableHandoffInvalid)
    {
        ViewData["SlimSeatedChrome"] = true;
    }
    else if (Model.HasSeatedTable)
    {
        ViewData["CompactGuestHeader"] = true;
    }
    var cartCatalogJson = JsonSerializer.Serialize(
        Model.CartCatalog.Select(r => new { id = r.Id, name = r.Name, price = r.Price }),
        new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase });
    var guestCtxJson = JsonSerializer.Serialize(
        new
        {
            seated = Model.HasSeatedTable,
            venueTableId = Model.VenueTableId?.ToString("D"),
            label = Model.TableGuestLabel
        },
        new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase });
}

@if (Model.QrScanInvalid || Model.TableHandoffInvalid)
{
    <partial name="Shared/_GuestTableContextNotice" model="Model" />
}
else if (Model.HasSeatedTable)
{
    <partial name="Shared/_GuestExperienceEntry" model="Model" />
    <partial name="Shared/_ArrivalScene" />
    <script type="application/json" id="menu-catalog-json">@Html.Raw(cartCatalogJson)</script>
    <script type="application/json" id="menu-guest-context">@Html.Raw(guestCtxJson)</script>
    <partial name="Shared/_OrderTrayDock" />
}
else
{
<div class="space-y-14 sm:space-y-24">
    <!-- 1) Hero -->
    <section class="pt-4 sm:pt-8">
        <div class="surface-paper overflow-hidden rounded-[2rem] px-7 py-12 sm:px-12 sm:py-16">
            <div class="postal-airmail-edge postal-airmail-edge--top -mx-7 mb-8 sm:-mx-12" aria-hidden="true"></div>
            <div class="max-w-2xl">
                <p class="postal-hero-kicker" data-i18n="home.postalFrom">From Kinini Village, Rwanda</p>
                <p class="mt-4 text-xs tracking-[0.32em] uppercase text-[rgb(var(--muted-2))]" data-i18n="home.brand">Annap Coffee Atelier</p>

                <h1 class="mt-6 text-[2.05rem] font-semibold leading-[1.08] tracking-tight text-[rgb(var(--fg))] sm:text-[3.1rem] sm:leading-[1.02] font-display">
                    <span data-i18n="home.heroLine1">Espresso. Filter.</span>
                    <span class="block text-[rgb(var(--muted))] font-normal">
                        <span data-i18n="home.heroLine2">Quiet sweetness.</span>
                    </span>
                </h1>

                <p class="mt-7 text-base leading-[1.55] text-[rgb(var(--muted))] md:text-lg" data-i18n="home.heroLead">
                    Warm cups. Clean finishes. Long aftertaste.
                </p>

                <div class="mt-6">
                    <span class="postal-stamp" data-i18n="home.postalStamp">Farm to cup</span>
                </div>

                @if (!Model.HasSeatedTable)
                {
                    <div class="mt-8 rounded-2xl border border-[rgba(212,184,150,0.55)] bg-[rgba(253,249,244,0.55)] px-5 py-4 text-sm leading-relaxed text-[rgb(var(--muted))]">
                        <span data-i18n="home.unseatedHint">To order and follow your tray, please scan the QR at your table. For a quiet preview of the room, you may still browse the menu.</span>
                        @if (Model.IsDevelopment)
                        {
                            <span class="mt-2 block text-xs text-[rgb(var(--muted-2))]"><span data-i18n="home.devTableSetup">Development:</span> <a class="underline underline-offset-4 hover:text-[rgb(var(--fg))]" href="/table/T12" data-i18n="home.devTableLink">Open table T12</a></span>
                        }
                    </div>
                }

                <div class="mt-10 flex flex-col gap-3 md:flex-row md:items-center">
                    <a asp-page="/Menu/Index" asp-route-vt="@Model.VenueTableId" class="btn-ink guest-hit w-full justify-center md:w-auto">
                        <span data-i18n="nav.menu">Menu</span>
                        <span aria-hidden="true" class="text-white/80">→</span>
                    </a>
                    <button type="button"
                            class="btn-quiet guest-hit w-full justify-center md:w-auto"
                            onclick="openCart()">
                        <span data-i18n="home.orderCta">Order</span>
                        <span id="cartCountPill"
                              class="ml-2 hidden rounded-full bg-[rgb(var(--accent))] px-2 py-0.5 text-xs font-semibold text-white">0</span>
                    </button>
                </div>

                <div class="mt-10 grid grid-cols-1 gap-3 text-sm text-[rgb(var(--muted))] md:grid-cols-2">
                    <div class="surface-glass rounded-[1.35rem] px-5 py-4">
                        <div class="flex items-center justify-between">
                            <span class="text-[rgb(var(--muted-2))] tracking-[0.22em] uppercase text-xs" data-i18n="home.statService">Service</span>
                            <span class="text-[rgb(var(--fg))]" data-i18n="home.statServiceValue">Quiet • precise</span>
                        </div>
                    </div>
                    <div class="surface-glass rounded-[1.35rem] px-5 py-4">
                        <div class="flex items-center justify-between">
                            <span class="text-[rgb(var(--muted-2))] tracking-[0.22em] uppercase text-xs" data-i18n="home.statProfile">Profile</span>
                            <span class="text-[rgb(var(--fg))]" data-i18n="home.statProfileValue">Citrus • cocoa</span>
                        </div>
                    </div>
                </div>

                <div class="postal-airmail-edge postal-airmail-edge--bottom -mx-7 mt-10 sm:-mx-12" aria-hidden="true"></div>
            </div>
        </div>
    </section>

    <!-- 2) Signature drinks preview -->
    <section aria-labelledby="signature">
        <div class="flex items-end justify-between gap-4">
            <div>
                <h2 id="signature" class="text-xl sm:text-2xl font-semibold tracking-tight text-[rgb(var(--fg))]" data-i18n="home.signatureHeading">
                    Signature cups
                </h2>
                <p class="mt-2 text-sm sm:text-base text-[rgb(var(--muted))]" data-i18n="home.signatureSub">
                    Balanced sweetness. Clean structure. Long finish.
                </p>
            </div>
            <a asp-page="/Menu/Index" asp-route-vt="@Model.VenueTableId" class="text-sm text-[rgb(var(--muted))] hover:text-[rgb(var(--fg))] underline underline-offset-4" data-i18n="home.signatureSeeAll">
                See all
            </a>
        </div>

        <div class="mt-8 grid grid-cols-1 gap-5 md:grid-cols-2">
            @foreach (var drink in Model.SignatureDrinks)
            {
                var detailHref = Model.VenueTableId is Guid vtid
                    ? $"/menu/drink/{drink.Id}?vt={vtid:D}"
                    : $"/menu/drink/{drink.Id}";
                var drinkIdStr = drink.Id.ToString("D");
                <article class="surface-paper relative rounded-[2rem] p-7 transition-transform duration-200 sm:hover:-translate-y-0.5">
                    <div class="relative z-[1] grid grid-cols-[96px_1fr] gap-5 md:grid-cols-[112px_1fr]">
                        <a href="@detailHref"
                           data-ge-open-detail="@drinkIdStr"
                           class="relative block min-h-[7.5rem] overflow-hidden rounded-[1.25rem] bg-[rgba(26,20,16,0.04)] ring-1 ring-[rgba(212,184,150,0.45)] focus:outline-none focus-visible:ring-2 focus-visible:ring-[rgb(var(--accent))]/35"
                           aria-label="@drink.Name — view details">
                            @if (!string.IsNullOrWhiteSpace(drink.CardImageUrl))
                            {
                                <img src="@drink.CardImageUrl"
                                     alt=""
                                     class="absolute inset-0 z-0 h-full w-full object-cover"
                                     width="960"
                                     height="720"
                                     loading="lazy"
                                     decoding="async"
                                     referrerpolicy="no-referrer" />
                            }
                            else
                            {
                                <div class="absolute inset-0 z-0 flex items-center justify-center bg-[rgba(26,20,16,0.04)] ge-sig-no-poster"
                                     aria-hidden="true">
                                    <span class="font-display text-3xl italic text-[rgb(var(--fg))]/70">@(string.IsNullOrEmpty(drink.Name) ? "·" : drink.Name[0])</span>
                                </div>
                            }
                            <div class="absolute inset-0 z-[1] bg-[radial-gradient(80px_80px_at_30%_20%,rgba(199,168,122,0.22),transparent_60%),radial-gradient(120px_100px_at_70%_80%,rgba(122,151,130,0.14),transparent_65%)]"></div>
                            <div class="absolute inset-0 z-[1] opacity-50 mix-blend-overlay" style="background-image: repeating-linear-gradient(0deg, rgba(255,255,255,0.06) 0, rgba(255,255,255,0.06) 1px, transparent 1px, transparent 4px);"></div>
                            <div class="absolute bottom-3 left-3 right-3 z-[1] text-[10px] tracking-[0.28em] uppercase text-[rgb(var(--muted-2))]" data-i18n="home.signatureCupBadge">
                                Cup
                            </div>
                        </a>

                        <div class="min-w-0">
                            <div class="flex items-start justify-between gap-4">
                                <div class="min-w-0">
                                    <p class="text-xs tracking-[0.28em] text-[rgb(var(--muted-2))] uppercase">@drink.CategoryName</p>
                                    <h3 class="mt-3 text-lg sm:text-xl font-semibold tracking-tight text-[rgb(var(--fg))]">@drink.Name</h3>
                                    @if (!string.IsNullOrWhiteSpace(drink.Subtitle))
                                    {
                                        <p class="mt-1 text-[11px] tracking-[0.18em] uppercase text-[rgb(var(--muted-2))]">@drink.Subtitle</p>
                                    }
                                </div>
                                <div class="text-sm font-semibold text-[rgb(var(--fg))] whitespace-nowrap pt-1">
                                    @drink.Price.ToString("C")
                                </div>
                            </div>

                            <button type="button"
                                    class="btn-ink guest-hit mt-5 w-full justify-center py-4 text-sm font-normal tracking-wide transition-transform active:scale-[0.99]"
                                    onclick="quickAdd('@drink.Id', undefined, this)"
                                    data-i18n="menu.addToTray">
                                Send to my table
                            </button>

                            @if (!string.IsNullOrWhiteSpace(drink.TastingLine))
                            {
                                <div class="mt-5">
                                    <div class="text-[10px] tracking-[0.28em] text-[rgb(var(--muted-2))] uppercase" data-i18n="menu.tastingNotesLabel">Tasting notes</div>
                                    <p class="mt-2 text-sm sm:text-base text-[rgb(var(--muted))] leading-relaxed">@drink.TastingLine</p>
                                </div>
                            }
                            @if (!string.IsNullOrWhiteSpace(drink.MoodProfile))
                            {
                                <p class="mt-3 text-xs tracking-[0.2em] uppercase text-[rgb(var(--muted-2))]">@drink.MoodProfile</p>
                            }

                            <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                                <a href="@detailHref"
                                   data-ge-open-detail="@drinkIdStr"
                                   class="guest-hit inline-flex min-h-11 items-center text-xs tracking-[0.18em] uppercase text-[rgb(var(--muted))] underline underline-offset-4 transition hover:text-[rgb(var(--fg))]"
                                   data-i18n="menu.discover">
                                    Discover
                                </a>
                                <button type="button"
                                        class="guest-hit min-h-11 text-left text-sm text-[rgb(var(--muted))] underline underline-offset-4 transition hover:text-[rgb(var(--fg))] sm:text-right"
                                        onclick="openCart()"
                                        data-i18n="cart.openSelections">
                                    Open order
                                </button>
                            </div>
                        </div>
                    </div>
                </article>
            }
        </div>
    </section>

    <!-- 3) Categories -->
    <section aria-labelledby="categories">
        <h2 id="categories" class="text-xl sm:text-2xl font-semibold tracking-tight text-[rgb(var(--fg))]" data-i18n="nav.menu">Menu</h2>
        <p class="mt-2 text-sm sm:text-base text-[rgb(var(--muted))]" data-i18n="home.categoriesHint">Choose a direction. We'll keep it simple.</p>

        <div class="mt-8 grid grid-cols-1 gap-2 md:grid-cols-3">
            @foreach (var c in Model.Categories)
            {
                <a asp-page="/Menu/Index" asp-route-vt="@Model.VenueTableId"
                   class="group surface-glass rounded-[1.5rem] px-6 py-6 transition-transform duration-200 sm:hover:-translate-y-0.5">
                    <div class="flex items-center justify-between gap-4">
                        <div>
                            <div class="text-base font-semibold tracking-tight text-[rgb(var(--fg))]">@c.Name</div>
                            <div class="mt-2 text-sm text-[rgb(var(--muted))]" data-i18n="home.tapBrowse">Tap to browse</div>
                        </div>
                        <div class="text-[rgb(var(--muted-2))] group-hover:text-[rgb(var(--fg))] transition">→</div>
                    </div>
                </a>
            }
        </div>
    </section>

    <!-- 4) House tasting ritual -->
    <section aria-labelledby="mood-heading" class="surface-paper mood-ritual-section rounded-[2rem] px-7 py-12 sm:px-12">
        <div class="max-w-5xl">
            <p class="text-xs tracking-[0.32em] text-[rgb(var(--muted-2))] uppercase" data-i18n="ritual.kicker">House tasting</p>
            <h2 id="mood-heading" class="mt-5 font-display text-2xl sm:text-3xl font-normal tracking-tight text-[rgb(var(--fg))] leading-snug" data-i18n="ritual.heading">
                Arrive by feeling; we’ll meet you in the room.
            </h2>
            <p class="mt-4 max-w-2xl text-sm sm:text-base leading-relaxed text-[rgb(var(--muted))]" data-i18n="ritual.intro">
                Moods are doorways—not switches. Your host reads the air, sets the tray in kind, and lets language settle the way a private tasting does: unhurried, editorial, never a catalogue.
            </p>

            <div id="moodChoices"
                 class="mood-choice-grid mt-10 grid grid-cols-1 gap-3 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5"
                 role="tablist"
                 data-i18n-aria="ritual.moodAria"
                 aria-label="How you wish to arrive">
                <button type="button"
                        class="mood-pill group text-left"
                        data-mood="bright"
                        role="tab"
                        aria-selected="false"
                        onclick="selectMood('bright')">
                    <span class="mood-pill-kicker" data-i18n="moods.bright.kicker">Lifted</span>
                    <span class="mood-pill-title" data-i18n="moods.bright.title">Bright &amp; citrusy</span>
                    <span class="mood-pill-line" data-i18n="moods.bright.line">Sunlit acidity, clean glass, a little electricity.</span>
                </button>
                <button type="button"
                        class="mood-pill group text-left"
                        data-mood="slow"
                        role="tab"
                        aria-selected="false"
                        onclick="selectMood('slow')">
                    <span class="mood-pill-kicker" data-i18n="moods.slow.kicker">Held</span>
                    <span class="mood-pill-title" data-i18n="moods.slow.title">Slow &amp; comforting</span>
                    <span class="mood-pill-line" data-i18n="moods.slow.line">Round sweetness, hush, something to linger inside.</span>
                </button>
                <button type="button"
                        class="mood-pill group text-left"
                        data-mood="floral"
                        role="tab"
                        aria-selected="false"
                        onclick="selectMood('floral')">
                    <span class="mood-pill-kicker" data-i18n="moods.floral.kicker">Soft</span>
                    <span class="mood-pill-title" data-i18n="moods.floral.title">Floral &amp; delicate</span>
                    <span class="mood-pill-line" data-i18n="moods.floral.line">Perfumed air, whispered sugar, porcelain calm.</span>
                </button>
                <button type="button"
                        class="mood-pill group text-left"
                        data-mood="adventurous"
                        role="tab"
                        aria-selected="false"
                        onclick="selectMood('adventurous')">
                    <span class="mood-pill-kicker" data-i18n="moods.adventurous.kicker">Brave</span>
                    <span class="mood-pill-title" data-i18n="moods.adventurous.title">Adventurous</span>
                    <span class="mood-pill-line" data-i18n="moods.adventurous.line">Layers that shift; spice, shadow, and return.</span>
                </button>
                <button type="button"
                        class="mood-pill group text-left sm:col-span-2 lg:col-span-1 xl:col-span-1"
                        data-mood="focus"
                        role="tab"
                        aria-selected="false"
                        onclick="selectMood('focus')">
                    <span class="mood-pill-kicker" data-i18n="moods.focus.kicker">Still</span>
                    <span class="mood-pill-title" data-i18n="moods.focus.title">Quiet focus</span>
                    <span class="mood-pill-line" data-i18n="moods.focus.line">Tea-like clarity for reading, thinking, or rain.</span>
                </button>
            </div>

            <p id="moodCatalogErr" class="mt-6 hidden text-sm text-red-200/90"></p>

            <div id="moodResults" class="mood-results mt-12 hidden" data-ritual-mood="">
                <div class="mood-results-grid grid gap-10 lg:grid-cols-12 lg:gap-12">
                    <div class="lg:col-span-5">
                        <article id="moodTastingCard" class="mood-tasting-card mood-sommelier-card surface-glass relative overflow-hidden rounded-[1.75rem] px-6 py-8 ring-1 ring-[rgba(212,184,150,0.45)] sm:px-8 sm:py-9">
                            <div id="moodSommelierShroud"
                                 class="sommelier-shroud pointer-events-none absolute inset-0 z-10 hidden flex-col justify-center gap-4 bg-[rgb(var(--paper)))]/88 px-6 py-10 backdrop-blur-[2px] sm:px-8"
                                 aria-live="polite"
                                 aria-busy="true">
                                <p class="text-[10px] font-medium tracking-[0.32em] uppercase text-[rgb(var(--muted-2))]" data-i18n="ritual.shroudKicker">House guide</p>
                                <div class="sommelier-quiet-line max-w-[14rem]" aria-hidden="true"></div>
                                <p class="max-w-xs text-sm leading-relaxed text-[rgb(var(--muted))]" data-i18n="ritual.shroudBody">Setting the room and drawing language from tonight’s parchment—no prompts, no chatter.</p>
                            </div>
                            <div id="moodSommelierInner" class="mood-sommelier-inner relative z-0">
                                <div class="mood-ritual-block" style="--ritual-i:0">
                                    <p class="text-[10px] font-medium tracking-[0.28em] uppercase text-[rgb(var(--muted-2))]" data-i18n="ritual.flavorPath">Flavor path</p>
                                    <p id="moodSenseTag" class="mt-2 hidden text-sm leading-snug text-[rgb(var(--accent))]"></p>
                                </div>
                                <div class="mood-ritual-block mt-7" style="--ritual-i:1">
                                    <p class="text-[10px] font-medium tracking-[0.28em] uppercase text-[rgb(var(--muted-2))]" data-i18n="ritual.tastingDirection">Tasting direction</p>
                                    <p id="moodTastingDirection" class="mt-2 text-sm leading-relaxed text-[rgb(var(--muted))] sm:text-base"></p>
                                </div>
                                <div class="hairline my-6 opacity-40"></div>
                                <div class="mood-ritual-block" style="--ritual-i:2">
                                    <p id="moodOpeningLetter" class="sommelier-opening font-display text-lg leading-snug text-[rgb(var(--fg))] sm:text-xl"></p>
                                </div>
                                <div class="hairline my-6 opacity-50"></div>
                                <div class="mood-ritual-block" style="--ritual-i:3">
                                    <p class="text-[10px] font-medium tracking-[0.28em] uppercase text-[rgb(var(--muted-2))]" data-i18n="ritual.beginWith">We’d begin with</p>
                                    <p id="moodRecName" class="mt-2 font-display text-2xl font-normal tracking-tight text-[rgb(var(--fg))] sm:text-[1.65rem]"></p>
                                    <button type="button" id="moodRecAdd" class="btn-ink mt-5 hidden w-full justify-center py-4 text-sm font-normal tracking-wide" data-i18n="menu.addToTray">Send to my table</button>
                                </div>
                                <div class="hairline my-6 opacity-50"></div>
                                <div class="mood-ritual-block" style="--ritual-i:4">
                                    <p class="text-[10px] font-medium tracking-[0.26em] uppercase text-[rgb(var(--muted-2))]" data-i18n="ritual.inTheCup">In the cup</p>
                                    <p id="moodTastingBody" class="mt-3 text-sm leading-[1.75] text-[rgb(var(--muted))] sm:text-base"></p>
                                </div>
                                <div class="mood-ritual-block mt-7" style="--ritual-i:5">
                                    <p class="text-[10px] font-medium tracking-[0.26em] uppercase text-[rgb(var(--muted-2))]" data-i18n="ritual.roomBriefly">The room, briefly</p>
                                    <p id="moodToneBody" class="mt-2 font-display text-lg leading-snug text-[rgb(var(--fg))]"></p>
                                </div>
                                <div class="mood-ritual-block mt-7" style="--ritual-i:6">
                                    <p class="text-[10px] font-medium tracking-[0.26em] uppercase text-[rgb(var(--muted-2))]" data-i18n="ritual.whyBelongs">Why it belongs</p>
                                    <p id="moodReasonBody" class="mt-3 text-sm leading-[1.75] text-[rgb(var(--muted))]"></p>
                                </div>
                                <div id="moodRefinementChips" class="mood-ritual-block mt-8 flex flex-col gap-3 border-t border-[rgba(212,184,150,0.35)] pt-6" style="--ritual-i:7" role="group" data-i18n-aria="ritual.refinementGroupAria" aria-label="Fine adjustments to the line"></div>
                                <div id="moodSecondGestureWrap" class="mood-ritual-block mt-8 hidden border-t border-[rgba(212,184,150,0.35)] pt-6" style="--ritual-i:8">
                                    <p class="text-[10px] font-medium tracking-[0.26em] uppercase text-[rgb(var(--muted-2))]" data-i18n="ritual.secondGesture">A second gesture</p>
                                    <p id="moodFollowUp" class="mt-3 text-sm leading-[1.75] text-[rgb(var(--muted))] sm:text-base"></p>
                                </div>
                                <div id="moodAlternativesWrap" class="mood-ritual-block mt-8 hidden border-t border-[rgba(212,184,150,0.35)] pt-6" style="--ritual-i:9">
                                    <p class="text-[10px] font-medium tracking-[0.28em] uppercase text-[rgb(var(--muted-2))]" data-i18n="ritual.otherDirections">Other directions</p>
                                    <p class="mt-1 text-xs leading-relaxed text-[rgb(var(--muted-2))]" data-i18n="ritual.otherDirectionsHint">Should you wish another line on the tray.</p>
                                    <div id="moodAlternatives" class="mt-4 flex flex-col gap-3"></div>
                                </div>
                                <div class="mood-ritual-block mt-8 flex flex-wrap items-center gap-3 border-t border-[rgba(212,184,150,0.35)] pt-6" style="--ritual-i:10">
                                    <button type="button" id="moodRecLink" data-ge-open-detail="" class="hidden text-sm text-[rgb(var(--muted))] underline underline-offset-4 transition hover:text-[rgb(var(--fg))]" data-i18n="ritual.readCup">Read the cup</button>
                                </div>
                            </div>
                        </article>
                    </div>
                    <div class="lg:col-span-7">
                        <div class="flex flex-col gap-2 md:flex-row md:items-end md:justify-between">
                            <div>
                                <p class="text-[10px] font-medium tracking-[0.28em] uppercase text-[rgb(var(--muted-2))]" data-i18n="ritual.cupsInLight">Cups in this light</p>
                                <p id="moodFilterCaption" class="mt-1 font-display text-lg text-[rgb(var(--fg))]"></p>
                            </div>
                            <a asp-page="/Menu/Index" asp-route-vt="@Model.VenueTableId" class="text-xs tracking-[0.2em] uppercase text-[rgb(var(--muted))] underline-offset-4 transition hover:text-[rgb(var(--accent))] hover:underline" data-i18n="ritual.fullMenu">Full menu</a>
                        </div>
                        <p id="moodPersonalityGlimpse" class="mood-personality-glimpse mt-4 hidden max-w-xl text-sm italic leading-relaxed text-[rgb(var(--muted))]" aria-live="polite"></p>
                        <div id="moodReadingRite" class="mood-reading-rite hidden mt-4 rounded-2xl border border-dashed border-[rgba(212,184,150,0.65)] bg-[rgba(253,249,244,0.88)] px-5 py-10 text-center shadow-[inset_0_1px_0_rgba(255,255,255,0.65)]" aria-live="polite" aria-atomic="true"></div>
                        <div id="moodDrinkGrid" class="mood-drink-grid mt-6 grid grid-cols-1 gap-4 md:grid-cols-2"></div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
}

