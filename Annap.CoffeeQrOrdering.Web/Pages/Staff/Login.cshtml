@page
@model LoginModel
@{
    Layout = "_StaffLayout";
    ViewData["Title"] = "Đăng nhập nhân viên";
}

<div class="mx-auto max-w-md space-y-8 px-4 py-16">
    <div class="text-center">
        <p class="text-[10px] font-medium tracking-[0.32em] uppercase text-[rgb(var(--muted-2))]">Annap Coffee Atelier</p>
        <h1 class="mt-4 font-display text-2xl tracking-tight text-[rgb(var(--fg))]">Sàn phục vụ</h1>
        <p class="mt-3 text-sm leading-relaxed text-[rgb(var(--muted))]">Đăng nhập để mở hàng đợi đơn hàng.</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="rounded-2xl border border-red-500/25 bg-red-500/10 px-4 py-3 text-sm text-red-200/90" role="alert">
            @Model.ErrorMessage
        </div>
    }

    <form method="post" class="space-y-5 rounded-2xl border border-white/[0.08] bg-white/[0.02] p-7 ring-1 ring-white/[0.06]">
        @Html.AntiForgeryToken()
        <div>
            <label class="block text-xs font-medium tracking-wide text-[rgb(var(--muted))]" for="UserName">Tên đăng nhập</label>
            <input id="UserName" name="UserName" asp-for="UserName" autocomplete="username"
                   class="mt-2 w-full rounded-xl bg-white/5 px-4 py-3 text-sm text-[rgb(var(--fg))] ring-1 ring-white/10 focus:outline-none focus:ring-2 focus:ring-white/15" />
        </div>
        <div>
            <label class="block text-xs font-medium tracking-wide text-[rgb(var(--muted))]" for="Password">Mật khẩu</label>
            <input id="Password" name="Password" asp-for="Password" type="password" autocomplete="current-password"
                   class="mt-2 w-full rounded-xl bg-white/5 px-4 py-3 text-sm text-[rgb(var(--fg))] ring-1 ring-white/10 focus:outline-none focus:ring-2 focus:ring-white/15" />
        </div>
        <button type="submit" class="btn-ink w-full justify-center py-3 text-sm">Vào sàn</button>
    </form>
</div>
