@page "/staff/login"
@model LoginModel
@{
    Layout = "_StaffLayout";
    ViewData["Title"] = L["ops.staff.login.title"];
}

@section Styles {
    <link rel="stylesheet" href="~/css/staff-login.css" asp-append-version="true" />
}

<div class="staff-login">
    <div class="staff-login__sheet">
        <header class="staff-login__header">
            <p class="staff-login__eyebrow">@L["ops.common.brand"]</p>
            <h1 class="staff-login__title">@L["ops.staff.login.title"]</h1>
            <p class="staff-login__subtitle">@L["ops.staff.login.subtitle"]</p>
        </header>

        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="staff-login__error" role="alert">@Model.ErrorMessage</div>
        }

        <form method="post" class="staff-login__form">
            @Html.AntiForgeryToken()
            <label class="staff-login__field" for="UserName">
                <span class="staff-login__label">@L["ops.staff.login.username"]</span>
                <input id="UserName"
                       name="UserName"
                       asp-for="UserName"
                       autocomplete="username"
                       placeholder="@L["ops.staff.login.usernamePlaceholder"]" />
                <span class="staff-login__hint">@L["ops.staff.login.usernameHint"]</span>
            </label>
            <label class="staff-login__field" for="Password">
                <span class="staff-login__label">@L["ops.staff.login.password"]</span>
                <input id="Password"
                       name="Password"
                       asp-for="Password"
                       type="password"
                       autocomplete="current-password"
                       placeholder="@L["ops.staff.login.passwordPlaceholder"]" />
                <span class="staff-login__hint staff-login__hint--shared">@L["ops.staff.login.passwordHint"]</span>
            </label>
            <button type="submit" class="staff-login__submit btn-ink">@L["ops.staff.login.submit"]</button>
        </form>
    </div>
</div>
