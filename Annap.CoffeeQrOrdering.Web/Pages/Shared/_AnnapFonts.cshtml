@*
  Annap typography — Google Fonts (display=swap, Vietnamese subset).
  Mode: "guest" loads Fraunces + Inter; "ops" loads Inter only (Staff floor).
  Admin layout uses "guest" mode for premium page titles with sparse display use.
*@
@model string
@{
    var mode = Model ?? "guest";
    var loadDisplay = mode == "guest";
}
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
@if (loadDisplay)
{
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;500;600;700&amp;family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet" />
}
else
{
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet" />
}
