@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment HostEnvironment
@inject Microsoft.Extensions.Options.IOptions<DiagnosticsOptions> DiagOptions
@{
    var useDevUi = HostEnvironment.IsDevelopment() || DiagOptions.Value.DeveloperOverlays;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>@ViewData["Title"] · Nhân viên</title>
    <partial name="Shared/_AnnapRuntimeHead" model="useDevUi" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;1,400&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/staff-board.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Annap.CoffeeQrOrdering.Web.styles.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
    <link rel="stylesheet" href="~/css/staff-correspondence.css" asp-append-version="true" />
</head>
<body class="staff-shell min-h-dvh antialiased font-sans font-light text-[rgb(var(--fg))]">
    <header class="staff-topbar sticky top-0 z-40 border-b border-white/[0.06] bg-[rgb(var(--bg))]/95 backdrop-blur-md">
        <div class="mx-auto flex max-w-[1800px] items-center justify-between gap-4 px-4 py-3 sm:px-6">
            <div class="flex min-w-0 items-center gap-4">
                <a class="shrink-0 text-[10px] font-medium tracking-[0.28em] uppercase text-[rgb(var(--muted))] transition hover:text-[rgb(var(--fg))]"
                   asp-page="/Index" title="Trang khách">Atelier</a>
                <div class="h-6 w-px bg-white/[0.08]" aria-hidden="true"></div>
                <h1 class="truncate font-display text-lg tracking-tight text-[rgb(var(--fg))] sm:text-xl">@ViewData["Title"]</h1>
            </div>
            <nav class="flex shrink-0 items-center gap-3 text-xs sm:gap-4">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a class="rounded-full px-3 py-2 tracking-wide text-[rgb(var(--muted))] ring-1 ring-white/[0.08] transition hover:bg-white/[0.05] hover:text-[rgb(var(--fg))] sm:px-4"
                       asp-page="/Admin/Index" title="Quản trị quán">Quản lý</a>
                    <form method="post" asp-page="/Staff/Logout" class="inline">
                        <button type="submit" class="rounded-full px-3 py-2 tracking-wide text-[rgb(var(--muted))] ring-1 ring-white/[0.08] transition hover:bg-white/[0.05] hover:text-[rgb(var(--fg))] sm:px-4">
                            Đăng xuất
                        </button>
                    </form>
                }
                else
                {
                    <a class="rounded-full px-3 py-2 tracking-wide text-[rgb(var(--muted))] ring-1 ring-white/[0.08] transition hover:bg-white/[0.05] hover:text-[rgb(var(--fg))] sm:px-4"
                       asp-page="/Staff/Login">Đăng nhập</a>
                }
                <a class="rounded-full px-3 py-2 tracking-wide text-[rgb(var(--muted))] ring-1 ring-white/[0.08] transition hover:bg-white/[0.05] hover:text-[rgb(var(--fg))] sm:px-4"
                   asp-page="/Menu/Index">Thực đơn</a>
            </nav>
        </div>
    </header>

    <main role="main" class="mx-auto max-w-[1800px] px-4 py-5 sm:px-6 sm:py-7">
        @RenderBody()
    </main>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @if (useDevUi && DiagOptions.Value.ShowLanDebugOverlay)
    {
        <div id="annap-lan-debug"
             class="fixed bottom-[max(0.5rem,env(safe-area-inset-bottom))] left-2 right-2 z-[100] max-h-[38vh] overflow-auto rounded-lg border border-amber-500/30 bg-black/85 p-2 font-mono text-[10px] leading-snug text-amber-100/95 shadow-lg sm:left-auto sm:right-3 sm:max-w-sm sm:text-[11px]"
             aria-live="polite"></div>
        <script src="~/js/guest-lan-debug.js" asp-append-version="true"></script>
        <script>
            try {
                if (window.AnnapGuestLanDebug) {
                    window.AnnapGuestLanDebug.setMenu("—");
                    window.AnnapGuestLanDebug.setHub("—");
                }
            } catch { /* ignore */ }
        </script>
    }
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
