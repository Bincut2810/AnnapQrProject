@model Annap.CoffeeQrOrdering.Web.Pages.IndexModel
@{
    var tableLabel = string.IsNullOrWhiteSpace(Model.TableGuestLabel) ? "" : Model.TableGuestLabel.Trim();
    var vt = Model.VenueTableId;

    // Prefer digits for lockup ("TABLE 05" / "Bàn 05"); fall back to raw label.
    var digits = System.Text.RegularExpressions.Regex.Match(tableLabel, @"\d+").Value;
    string tableNumber;
    if (!string.IsNullOrEmpty(digits))
        tableNumber = digits.Length == 1 ? "0" + digits : digits;
    else if (!string.IsNullOrEmpty(tableLabel))
        tableNumber = tableLabel;
    else
        tableNumber = "—";

    var tableLineVi = "Bàn " + tableNumber;
    var tableLineEn = "TABLE " + tableNumber;
}
<link rel="stylesheet" href="~/css/arrival.css" asp-append-version="true" />
<div id="annap-arrival"
     class="annap-arrival"
     role="region"
     aria-labelledby="annap-arrival-title"
     data-table-vi="@tableLineVi"
     data-table-en="@tableLineEn"
     data-welcome-vi="Sẵn sàng phục vụ"
     data-welcome-en="Welcome.">

    <div class="annap-arrival__stage" aria-hidden="true">
        <img class="annap-arrival__photo"
             src="~/images/arrival/AnnapBackground.webp"
             asp-append-version="true"
             alt=""
             width="1080"
             height="1350"
             decoding="async"
             fetchpriority="high" />
        <div class="annap-arrival__overlay"></div>
    </div>

    <div class="annap-arrival__safe">
        <div class="annap-arrival__gate">
            <h1 class="annap-arrival__headline" id="annap-arrival-title">
                <span class="annap-arrival__table" id="annap-arrival-table">@tableLineVi</span>
                <span class="annap-arrival__welcome" id="annap-arrival-welcome" data-i18n="ge.arrival.welcomeWord">Sẵn sàng phục vụ</span>
            </h1>
        </div>

        <div class="annap-arrival__actions">
            <button type="button"
                    class="annap-arrival__invite"
                    id="annap-arrival-invite">
                <span class="annap-arrival__cta-text" data-i18n="ge.arrival.inviteIn">Mời bạn</span>
                <span class="annap-arrival__cta-arrow" aria-hidden="true">→</span>
            </button>

            @if (vt is Guid menuVt)
            {
                <a class="annap-arrival__menu"
                   id="annap-arrival-menu"
                   asp-page="/Menu/Index"
                   asp-route-vt="@menuVt">
                    <span class="annap-arrival__cta-text" data-i18n="ge.arrival.menuWord">Thực đơn</span>
                    <span class="annap-arrival__cta-arrow" aria-hidden="true">→</span>
                </a>
            }
            else
            {
                <a class="annap-arrival__menu"
                   id="annap-arrival-menu"
                   asp-page="/Menu/Index">
                    <span class="annap-arrival__cta-text" data-i18n="ge.arrival.menuWord">Thực đơn</span>
                    <span class="annap-arrival__cta-arrow" aria-hidden="true">→</span>
                </a>
            }
        </div>
    </div>
</div>
<script>
!function(){try{var d=document.documentElement;if(sessionStorage.getItem("annap_arrival_done")==="1"){var e=document.getElementById("annap-arrival");e&&(e.hidden=!0,e.setAttribute("aria-hidden","true"),e.classList.add("is-done"));d.classList.remove("annap-arrival-active")}else{d.classList.add("annap-arrival-active")}}catch(e){}}();
</script>
