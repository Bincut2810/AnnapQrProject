@inject Microsoft.AspNetCore.Hosting.IWebHostEnvironment HostEnvironment
@inject Microsoft.Extensions.Options.IOptions<DiagnosticsOptions> DiagOptions
@inject IHttpContextAccessor HttpContextAccessor
@{
    var useDevUi = HostEnvironment.IsDevelopment() || DiagOptions.Value.DeveloperOverlays;
    var slimGuestBoot = useDevUi && DiagOptions.Value.SlimGuestBoot;
    var devErrorCapture = useDevUi && DiagOptions.Value.GlobalErrorCapture;
    var http = HttpContextAccessor.HttpContext!.Request;
    var guestBoot = GuestBootResolver.Resolve(
        useDevUi,
        DiagOptions.Value,
        http.Query["safe"].FirstOrDefault(),
        http.Query["bootcheck"].FirstOrDefault());
    var guestBootJson = JsonSerializer.Serialize(guestBoot, new JsonSerializerOptions { PropertyNamingPolicy = JsonNamingPolicy.CamelCase });
    var skipQueue = slimGuestBoot || guestBoot.DisableGuestQueue;
    var skipI18n = slimGuestBoot || guestBoot.DisableI18n;
    var guestNoMotion = guestBoot.DisableGuestAnimations;
    // Pages that suppress the guest header/nav (Menu, Drink detail) set ViewData["IsSeatedPage"] = true.
    // The home page (Index) must NEVER get annap-seated-guest, even when ?vt= is present in the URL
    // or after a non-bfcache back-navigation from Menu.
    var isSeatedContext = ViewData["IsSeatedPage"] is true;
    var slimSeatedChrome = ViewData["SlimSeatedChrome"] is true;
    var compactGuestHeader = ViewData["CompactGuestHeader"] is true;
    var seatedSlimChrome = isSeatedContext || slimSeatedChrome;
    var isTableNotice = slimSeatedChrome && !isSeatedContext;
}
<!DOCTYPE html>
<html lang="en" class="annap-correspond-ui@(guestNoMotion ? " annap-guest-no-motion" : "")@(isSeatedContext ? " annap-seated-guest" : "")@(isTableNotice ? " annap-table-notice" : "")@(compactGuestHeader ? " annap-compact-guest-header" : "")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="theme-color" content="#faf7f2" />
    <meta name="color-scheme" content="dark light" />
    <title>@ViewData["Title"] - Annap Coffee Atelier</title>
    <partial name="Shared/_AnnapRuntimeHead" model="useDevUi" />
    <partial name="Shared/_AnnapFonts" model="@("guest")" />
    @if (devErrorCapture)
    {
        <script src="~/js/guest-dev-global-errors.js" asp-append-version="true"></script>
    }
    @* FORENSICS — load first so History.prototype is patched before any other script.
       Activate: sessionStorage.annap_forensics = "1"; location.reload();
       Dump:     copy(window.__annapForensicsDump()); *@
    @if (useDevUi)
    {
        <script src="~/js/annap-forensics.js" asp-append-version="true"></script>
    }
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/correspondence.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/menu-browse.css" asp-append-version="true" />
    @if (!seatedSlimChrome)
    {
        <link rel="stylesheet" href="~/css/menu-browse-physical.css" asp-append-version="true" />
    }
    <link rel="stylesheet" href="~/css/drink-detail.css" asp-append-version="true" />
    @if (!seatedSlimChrome)
    {
        <link rel="stylesheet" href="~/css/atmosphere-modes.css" asp-append-version="true" />
    }
    <link rel="stylesheet" href="~/Annap.CoffeeQrOrdering.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/typography-brand.css" asp-append-version="true" />
    <script src="~/js/annap-viewport.js" asp-append-version="true"></script>
    @if (!isSeatedContext)
    {
        <script src="~/js/modes/atmosphereManager.js" asp-append-version="true"></script>
        <script src="~/js/ambient.js" asp-append-version="true" defer></script>
    }
    <style>
        html.annap-guest-no-motion .mood-results,
        html.annap-guest-no-motion .mood-grid--enter .mood-drink-card,
        html.annap-guest-no-motion .mood-tasting-card,
        html.annap-guest-no-motion .order-tray-sheet,
        html.annap-guest-no-motion #drink-detail-panel,
        html.annap-guest-no-motion #drink-detail-modal {
            animation: none !important;
            transition: none !important;
        }
        #annap-boot-overlay .annap-boot-spinbar {
            height: 3px;
            border-radius: 2px;
            background: rgba(255,255,255,.12);
            overflow: hidden;
        }
        #annap-boot-overlay .annap-boot-spinbar > i {
            display: block;
            height: 100%;
            width: 25%;
            background: rgba(199,168,122,.85);
            animation: annapBootIndet 1.1s ease-in-out infinite alternate;
        }
        @@keyframes annapBootIndet {
            0% { transform: translateX(0); opacity: .7; }
            100% { transform: translateX(300%); opacity: 1; }
        }
        html.annap-guest-no-motion #annap-boot-overlay .annap-boot-spinbar > i { animation: none; }
    </style>
</head>
<body class="guest-app min-h-dvh overflow-x-hidden antialiased font-normal text-[rgb(var(--fg))]">
    <div id="annap-root" class="annap-root">
        @if (!seatedSlimChrome)
        {
        <div class="annap-ambient-stack" aria-hidden="true">
            <div class="annap-ambient-bg"></div>
            <div class="annap-ambient-thermal" aria-hidden="true"></div>
            <div class="annap-ambient-grain"></div>
        </div>
        }
        <div class="annap-root-surface">
    @if (!seatedSlimChrome)
    {
    <header class="guest-header guest-masthead@(compactGuestHeader ? " guest-masthead--compact" : "") sticky top-0 z-40 pt-[max(0.35rem,env(safe-area-inset-top))]">
        <div class="mx-auto max-w-5xl px-4 sm:px-4">
            <div class="guest-masthead__sheet surface-glass overflow-hidden rounded-sm shadow-[inset_0_1px_0_rgba(255,255,255,0.45),0_10px_32px_-12px_rgba(26,18,9,0.08)] sm:rounded-sm">
                <div class="postal-airmail-edge postal-airmail-edge--top" aria-hidden="true"></div>
                <div class="px-4 py-[max(0.75rem,2.2vh)] sm:px-5 sm:py-[max(0.85rem,2.4vh)]">
                <div class="flex flex-col gap-[max(0.75rem,2vh)] lg:flex-row lg:items-center lg:justify-between lg:gap-4">
                    <a class="guest-hit guest-masthead__mark inline-flex min-h-11 max-w-full items-center font-display text-[0.72rem] font-medium tracking-[0.06em] text-[rgb(var(--muted))] transition active:opacity-80 sm:text-xs"
                       asp-page="/Index"
                       data-guest-vt-link="1">
                        Annap Coffee Atelier
                    </a>
                    <nav class="guest-masthead__nav flex flex-wrap items-center gap-x-2 gap-y-2 border-t border-[rgba(190,165,130,0.28)] pt-3 text-xs lg:gap-x-3 lg:border-t-0 lg:pt-0 lg:text-sm" data-i18n-aria="nav.siteAria">
                        <span class="hidden min-h-11 items-center text-[10px] tracking-[0.18em] text-[rgb(var(--muted-2))] lg:inline-flex" data-i18n="langSwitcher.label">Language</span>
                        <div class="guest-lang-register flex min-h-11 items-center gap-0 border border-[rgba(190,165,130,0.42)] bg-[rgba(253,249,244,0.4)] p-px" role="group" data-i18n-aria="langSwitcher.label">
                            <button type="button" data-lang-set="en" class="guest-hit inline-flex min-h-11 min-w-11 items-center justify-center rounded-full px-3 text-xs tracking-[0.16em] transition hover:text-[rgb(var(--fg))] active:scale-[0.97] lg:tracking-[0.18em]" data-i18n="langSwitcher.en">EN</button>
                            <button type="button" data-lang-set="vi" class="guest-hit inline-flex min-h-11 min-w-11 items-center justify-center rounded-full px-3 text-xs tracking-[0.16em] transition hover:text-[rgb(var(--fg))] active:scale-[0.97] lg:tracking-[0.18em]" data-i18n="langSwitcher.vi">VI</button>
                        </div>
                        <a class="guest-hit inline-flex min-h-11 items-center px-2 text-[rgb(var(--muted))] transition hover:text-[rgb(var(--fg))] active:opacity-80"
                           asp-page="/Menu/Index"
                           data-guest-vt-link="1"
                           data-i18n="nav.menu">Menu</a>
                        <a class="guest-hit inline-flex min-h-11 items-center px-2 text-[rgb(var(--muted))] transition hover:text-[rgb(var(--fg))] active:opacity-80"
                           asp-page="/Staff/Orders" data-i18n="nav.staff">Staff</a>
                        <a class="guest-hit inline-flex min-h-11 items-center px-2 text-[rgb(var(--muted))] transition hover:text-[rgb(var(--fg))] active:opacity-80"
                           asp-page="/Privacy" data-i18n="nav.privacy">Privacy</a>
                    </nav>
                </div>
                </div>
            </div>
        </div>
    </header>
    }

    <main role="main" class="guest-main mx-auto max-w-5xl px-4 pb-[max(2.5rem,env(safe-area-inset-bottom))] lg:px-4@(seatedSlimChrome ? " guest-main--seated pt-[max(0.5rem,env(safe-area-inset-top))]" : "")">
            @RenderBody()
    </main>

    @if (guestBoot.ShowBootChecklist && !seatedSlimChrome)
    {
        <div id="annap-boot-overlay"
             class="fixed top-[max(4.25rem,env(safe-area-inset-top))] right-2 z-[250] max-w-[min(20rem,calc(100vw-1rem))] pointer-events-none max-md:right-2 max-md:left-auto sm:top-[max(5rem,env(safe-area-inset-top))]"
             aria-live="polite">
            <div class="pointer-events-auto surface-glass rounded-xl border border-white/[0.1] p-3 text-[rgb(var(--fg))] shadow-xl ring-1 ring-white/[0.06]">
                <p class="text-[10px] font-medium tracking-[0.2em] uppercase text-[rgb(var(--muted-2))]">Guest boot</p>
                <div id="annap-boot-spinner" class="annap-boot-spinbar mt-2"><i></i></div>
                <ul id="annap-boot-list" class="mt-2 list-none space-y-0.5 p-0 font-mono text-[9px] leading-snug text-[rgb(var(--muted))]">
                    <li data-annap-boot-row="css" data-label="CSS">[…] CSS</li>
                    <li data-annap-boot-row="js" data-label="JS">[…] JS</li>
                    <li data-annap-boot-row="viewport" data-label="Viewport">[…] Viewport</li>
                    <li data-annap-boot-row="i18n" data-label="i18n">[…] i18n</li>
                    <li data-annap-boot-row="menu" data-label="Menu">[…] Menu</li>
                    <li data-annap-boot-row="mood" data-label="Mood">[…] Mood</li>
                    <li data-annap-boot-row="sommelier" data-label="Sommelier">[…] Sommelier</li>
                    <li data-annap-boot-row="hydration" data-label="Hydration">[…] Hydration</li>
                    <li data-annap-boot-row="signalr" data-label="SignalR">[…] SignalR</li>
                    <li data-annap-boot-row="queue" data-label="Queue">[…] Queue</li>
                    <li data-annap-boot-row="observers" data-label="Observers">[…] Observers</li>
                </ul>
                <p id="annap-boot-safe-note" class="mt-2 min-h-[1em] text-[9px] text-[rgb(var(--muted-2))]"></p>
            </div>
        </div>
    }
    else
    {
        <div id="annap-boot-overlay" class="hidden" aria-hidden="true"></div>
    }

    @if (!seatedSlimChrome)
    {
    <footer class="pb-[max(2rem,env(safe-area-inset-bottom))] pt-4">
        <div class="mx-auto max-w-5xl px-4 text-[10px] tracking-[0.16em] text-[rgb(var(--muted-2))] lg:text-xs lg:tracking-[0.18em]">
            &copy; @DateTimeOffset.UtcNow.Year - Annap Coffee Atelier
        </div>
    </footer>
    }
        </div>

    <div id="guestToast" class="fixed left-4 right-4 z-50 hidden [bottom:max(1rem,calc(env(safe-area-inset-bottom)+var(--keyboard-inset,0px)))]">
        <div class="mx-auto max-w-5xl">
            <div class="surface-glass inline-flex min-h-12 items-center gap-3 rounded-sm border border-[rgba(190,165,130,0.35)] px-5 py-3 shadow-[inset_0_1px_0_rgba(255,255,255,0.4),0_8px_24px_-12px_rgba(26,18,9,0.1)]">
                <div class="text-sm text-[rgb(var(--fg))]" id="guestToastText" data-i18n="toast.addedShort">Added.</div>
                <button type="button" id="guestToastViewTray" class="guest-hit min-h-11 px-3 text-sm text-[rgb(var(--muted))] hover:text-[rgb(var(--fg))] underline underline-offset-4" data-i18n="toast.viewOpen">View tray</button>
            </div>
        </div>
    </div>

    <script type="application/json" id="annap-guest-boot-json">@Html.Raw(guestBootJson)</script>
    <script src="~/js/guest-boot-harness.js" asp-append-version="true"></script>
    <script src="~/js/annap-money.js" asp-append-version="true"></script>
    @if (!skipQueue)
    {
        <script src="~/js/guest-order-queue.js" asp-append-version="true"></script>
    }
    <script src="~/js/site.js" asp-append-version="true" defer></script>
    @if (!seatedSlimChrome)
    {
        <script src="~/js/add-to-order-animation-provider.js" asp-append-version="true" defer></script>
    }
    <script src="~/js/correspondence.js" asp-append-version="true" defer></script>
    @if (skipI18n)
    {
        <script>
            window.LuxuryI18n = window.LuxuryI18n || {
                ready: Promise.resolve(),
                t: function () { return ""; },
                tf: function () { return ""; },
                applyDom: function () {},
                wireSwitcher: function () {},
                getLang: function () { return "en"; },
                setLang: function () {}
            };
        </script>
    }
    else
    {
        <script src="~/js/guest-i18n.js" asp-append-version="true"></script>
    }
    @if (!slimGuestBoot && !seatedSlimChrome)
    {
        <script src="~/js/guest-interaction-contract.js" asp-append-version="true"></script>
        <script src="~/js/guest-feedback.js" asp-append-version="true"></script>
    }
    else if (seatedSlimChrome)
    {
        <script src="~/js/guest-interaction-contract.js" asp-append-version="true"></script>
    }

    @if (useDevUi && DiagOptions.Value.ShowLanDebugOverlay)
    {
        <div id="annap-lan-debug"
             class="fixed bottom-[max(0.5rem,env(safe-area-inset-bottom))] left-2 right-2 z-[100] max-h-[38vh] overflow-auto rounded-lg border border-amber-500/30 bg-black/85 p-2 font-mono text-[10px] leading-snug text-amber-100/95 shadow-lg sm:left-auto sm:right-3 sm:max-w-sm sm:text-[11px]"
             aria-live="polite"></div>
        <script src="~/js/guest-lan-debug.js" asp-append-version="true"></script>
        <script>
            if ("serviceWorker" in navigator) {
                navigator.serviceWorker.getRegistrations().then(function (rs) {
                    rs.forEach(function (r) {
                        r.unregister();
                    });
                });
            }
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
    <script>
@if (HostEnvironment.IsDevelopment())
{
        <text>/* Service worker disabled in Development — avoids stale /api/menu handlers on LAN devices. */</text>
}
else
{
        <text>
        if ("serviceWorker" in navigator) {
            window.addEventListener("load", function () {
                navigator.serviceWorker.register("/sw.js").catch(function () { });
            });
        }
        </text>
}
    </script>
    </div>
</body>
</html>
