@* Scene 01 — QR Arrival (seated Index only). Ceremonial sealed letter; no chrome, no spinner. *@
<link rel="stylesheet" href="~/css/arrival-scene.css" asp-append-version="true" />
<div id="annap-arrival-scene"
     class="annap-arrival-scene"
     role="region"
     aria-label="Welcome"
     aria-hidden="false"
     data-annap-arrival="1">
    <div class="annap-arrival-scene__canvas">
        <div class="aas-desk" aria-hidden="true"></div>
        <div class="aas-stage">
            <div class="aas-envelope-wrap">
                <div class="aas-envelope" aria-hidden="true">
                    <div class="aas-env__body"></div>
                    <div class="aas-env__cavity">
                        <div class="aas-letter">
                            <p class="aas-letter__line" data-i18n="ge.arrival.letterGreeting">Something has been prepared for this table.</p>
                            <p class="aas-letter__mark">ANNAP</p>
                        </div>
                    </div>
                    <div class="aas-env__flap"></div>
                    <div class="aas-env__seal"><span class="aas-env__seal-glyph" aria-hidden="true">&#10022;</span></div>
                </div>
            </div>
            <p class="aas-table-label" aria-live="polite"></p>
        </div>
    </div>
</div>
<script>
    !function () {
        try {
            if (sessionStorage.getItem("annap_arrival_done") === "1") {
                var s = document.getElementById("annap-arrival-scene");
                if (s) {
                    s.style.transition = "none";
                    s.style.visibility = "hidden";
                    s.style.opacity = "0";
                    s.style.pointerEvents = "none";
                    s.classList.add("annap-arrival-scene--done");
                    s.setAttribute("aria-hidden", "true");
                }
                document.documentElement.classList.remove("annap-arrival-scene-active", "annap-arrival-scene--arrival-overflow");
            }
        } catch (_) {}
    }();
</script>
