@page "/admin/menu/edit/{id:guid}"
@using System.Text.Json
@model EditModel
@{
    ViewData["Title"] = "Chỉnh sửa đồ uống";
    ViewData["AdminNavSection"] = "menu";
    ViewData["AdminEyebrow"] = "Danh sách đồ uống";
    ViewData["AdminReturnHref"] = Url.Content("~/admin");
    ViewData["AdminReturnLabel"] = "← Quay lại";
    var editorModel = new MenuCurationEditorPartialModel
    {
        Input = Model.Input,
        Categories = Model.CategoryOptions,
        CurrentHeroUrl = Model.CurrentHeroUrl,
        CurrentDetailPosterUrl = Model.CurrentDetailPosterUrl,
        PreviewCorrelationId = Model.MenuItemId,
        IsEdit = true
    };
}

<partial name="Admin/_AdminEditorialReturn" />
<section class="menu-curation-page">
    <partial name="_MenuCurationHero" model="Model.Hero" />

    @if (TempData["MenuCurationToast"] is string tedit)
    {
        <div class="menu-curation-toast" role="status">@tedit</div>
    }

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="mx-auto mb-8 max-w-3xl rounded-2xl border border-red-500/20 bg-red-500/10 px-5 py-4 text-sm text-red-200/90" asp-validation-summary="All"></div>
    }

    @if (Model.IsArchived)
    {
        <div class="mx-auto mb-8 max-w-3xl rounded-2xl border border-white/[0.08] bg-white/[0.03] px-5 py-4 text-sm text-[rgb(var(--muted))]">
            Ly này đã <span class="text-[rgb(var(--fg))]">được lưu trữ</span> — không còn hiện trên thực đơn hoặc cho phép đặt hàng. Khôi phục khi quán muốn cho khách thấy lại.
        </div>
    }

    <div class="mx-auto mb-6 flex max-w-3xl flex-wrap items-center gap-3">
        @if (Model.IsArchived)
        {
            <form method="post" asp-page-handler="Restore" asp-route-id="@Model.MenuItemId" class="inline">
                <button type="submit" class="admin-btn admin-btn--primary guest-hit min-h-11 px-6 tracking-[0.12em]">Khôi phục vào danh sách</button>
            </form>
        }
        else
        {
            <form method="post" asp-page-handler="Archive" asp-route-id="@Model.MenuItemId" class="inline"
                  onsubmit="return confirm('Lưu trữ ly này? Ly sẽ không còn hiện trên thực đơn nhưng vẫn giữ trong danh sách quản lý.');">
                <button type="submit" class="admin-btn admin-btn--ghost guest-hit min-h-11 px-6 tracking-[0.12em] text-[rgb(var(--muted))] ring-white/[0.12]">
                    Lưu trữ ly
                </button>
            </form>
        }
    </div>

    <form method="post"
          enctype="multipart/form-data"
          asp-page="/Admin/Menu/Edit"
          asp-route-id="@Model.MenuItemId"
          id="menu-curation-form"
          class="menu-curation-split"
          data-menu-curation-form
          data-category-labels='@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CategoryOptions.ToDictionary(c => c.Id.ToString("D"), c => c.Name)))'>
        <div class="menu-curation-split__editor">
            <partial name="_MenuCurationEditorForm" model="editorModel" />

            <div class="menu-curation-save-strip menu-curation-save-strip--calm" id="menu-curation-save-strip" aria-live="polite">
                <p class="menu-curation-save-strip__state" id="menu-curation-dirty-state">Chưa có thay đổi</p>
                <button type="submit" class="admin-btn admin-btn--primary guest-hit min-h-12 px-8 tracking-[0.12em]">
                    Lưu thay đổi
                </button>
            </div>
        </div>
        <aside class="menu-curation-split__preview" aria-label="Xem trước trực tiếp">
            <div class="menu-curation-preview-sticky">
                <partial name="_MenuCurationPreviewCard" model="Model.Preview" />
            </div>
        </aside>
    </form>
</section>

@section Scripts
{
    <script src="~/js/menu-curation.js" asp-append-version="true"></script>
}
